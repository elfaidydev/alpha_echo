<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Premium Target Kanban View -->
    <record id="view_alpha_echo_target_kanban" model="ir.ui.view">
        <field name="name">alpha.echo.target.kanban</field>
        <field name="model">alpha.echo.target</field>
        <field name="arch" type="xml">
            <kanban default_group_by="category" class="o_kanban_mobile" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="handle"/>
                <field name="category"/>
                <field name="is_active"/>
                <field name="image_1920"/>
                <field name="posts_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click oe_kanban_card d-flex flex-column">
                            <div class="o_kanban_record_top mb-2">
                                <div class="o_kanban_record_headings d-flex align-items-center">
                                    <div class="o_kanban_image me-2">
                                        <img t-att-src="kanban_image('alpha.echo.target', 'image_1920', record.id.raw_value)" alt="Logo" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover; border: 1px solid #dee2e6;"/>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <strong class="o_kanban_record_title fs-5 mb-0">
                                            <field name="name"/>
                                        </strong>
                                        <span class="text-muted small"><i class="fa fa-twitter text-info me-1" title="Twitter Handle"/> <field name="handle"/></span>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom mt-auto">
                                <div class="oe_kanban_bottom_left">
                                    <span class="badge rounded-pill text-bg-success" t-if="record.is_active.raw_value">
                                        <i class="fa fa-check-circle me-1"/> Active
                                    </span>
                                    <span class="badge rounded-pill text-bg-secondary" t-if="!record.is_active.raw_value">
                                        <i class="fa fa-pause-circle me-1"/> Paused
                                    </span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <span class="text-muted fw-bold" title="Total Posts Detected">
                                        <i class="fa fa-file-text-o me-1"/> <field name="posts_count"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Standard Tree View -->
    <record id="view_alpha_echo_target_tree" model="ir.ui.view">
        <field name="name">alpha.echo.target.tree</field>
        <field name="model">alpha.echo.target</field>
        <field name="arch" type="xml">
            <tree string="Managed Targets" decoration-muted="not is_active">
                <field name="name"/>
                <field name="handle"/>
                <field name="category"/>
                <field name="posts_count"/>
                <field name="last_scanned"/>
                <field name="is_active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Premium Form View -->
    <record id="view_alpha_echo_target_form" model="ir.ui.view">
        <field name="name">alpha.echo.target.form</field>
        <field name="model">alpha.echo.target</field>
        <field name="arch" type="xml">
            <form string="Target Configuration" class="o_form_project_tasks">
                <header>
                    <button name="cron_fetch_all_targets" string="Update Now" type="object" class="btn-primary" icon="fa-refresh"/>
                </header>
                <sheet class="pe-5 ps-5 pb-5 pt-4 bg-white rounded-4 shadow-sm border-0 mt-4 mb-4" style="max-width: 900px; margin: 0 auto;">
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_posts" icon="fa-file-text-o" invisible="posts_count == 0">
                            <field string="Discovered Posts" name="posts_count" widget="statinfo"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="Paused" bg_color="text-bg-warning" invisible="is_active"/>
                    <widget name="web_ribbon" title="Monitoring" bg_color="text-bg-success" invisible="not is_active"/>
                    
                    <div class="d-flex align-items-center mb-5 pb-4 border-bottom">
                        <div class="me-4 ms-2">
                            <field name="image_1920" widget="image" class="oe_avatar shadow-sm rounded-4 border border-light" options="{'preview_image': 'image_128'}" style="width: 100px; height: 100px; object-fit: contain; background: #fff; padding: 4px;"/>
                        </div>
                        <div class="oe_title flex-grow-1 ms-3">
                            <label for="name" class="oe_edit_only text-muted fw-bold mb-2 fs-6 tracking-wide" string="Target Entity Name"/>
                            <h1 class="mb-0 text-dark" style="font-weight: 900; font-size: 2rem; color: #0f172a;">
                                <field name="name" placeholder="Example: King Salman Relief Center"/>
                            </h1>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-6 pe-md-4 border-end">
                            <group name="Identity" string="Digital Identity" class="fw-bold" style="color: #4338ca;">
                                <field name="handle" placeholder="Example: @KSRelief" widget="url" class="fw-medium text-dark mt-2 mb-3"/>
                                <field name="category" class="fw-medium text-dark"/>
                            </group>
                        </div>
                        <div class="col-md-6 ps-md-4">
                            <group name="Engine" string="Smart Engine" class="fw-bold text-success">
                                <field name="is_active" widget="boolean_toggle" class="fw-medium text-dark mt-2 mb-3"/>
                                <field name="last_scanned" readonly="1" class="text-muted"/>
                            </group>
                        </div>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_alpha_echo_target" model="ir.actions.act_window">
        <field name="name">Monitored Targets</field>
        <field name="res_model">alpha.echo.target</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            Add your first donor or organization to begin!
          </p>
          <p>
            The system will monitor their activity and capture initiatives automatically.
          </p>
        </field>
    </record>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Premium Target Kanban View -->
    <record id="view_smart_radar_target_kanban" model="ir.ui.view">
        <field name="name">smart.radar.target.kanban</field>
        <field name="model">smart.radar.target</field>
        <field name="arch" type="xml">
            <kanban default_group_by="category" class="o_kanban_mobile" sample="1">
                <field name="id"/>
                <field name="name"/>
                <field name="handle"/>
                <field name="category"/>
                <field name="is_active"/>
                <field name="image_1920"/>
                <field name="posts_count"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click oe_kanban_card d-flex flex-column">
                            <div class="o_kanban_record_top mb-2">
                                <div class="o_kanban_record_headings d-flex align-items-center">
                                    <div class="o_kanban_image me-2">
                                        <img t-att-src="kanban_image('smart.radar.target', 'image_1920', record.id.raw_value)" alt="Logo" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover; border: 1px solid #dee2e6;"/>
                                    </div>
                                    <div class="d-flex flex-column">
                                        <strong class="o_kanban_record_title fs-5 mb-0">
                                            <field name="name"/>
                                        </strong>
                                        <span class="text-muted small"><i class="fa fa-twitter text-info me-1"/> <field name="handle"/></span>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_record_bottom mt-auto">
                                <div class="oe_kanban_bottom_left">
                                    <span class="badge rounded-pill text-bg-success" t-if="record.is_active.raw_value">
                                        <i class="fa fa-check-circle me-1"/> نشط للمراقبة
                                    </span>
                                    <span class="badge rounded-pill text-bg-secondary" t-if="!record.is_active.raw_value">
                                        <i class="fa fa-pause-circle me-1"/> موقوف
                                    </span>
                                </div>
                                <div class="oe_kanban_bottom_right">
                                    <span class="text-muted fw-bold" title="Total Grants Detected">
                                        <i class="fa fa-file-text-o me-1"/> <field name="posts_count"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Standard Tree View -->
    <record id="view_smart_radar_target_tree" model="ir.ui.view">
        <field name="name">smart.radar.target.tree</field>
        <field name="model">smart.radar.target</field>
        <field name="arch" type="xml">
            <tree string="Managed Targets" decoration-muted="not is_active">
                <field name="name"/>
                <field name="handle"/>
                <field name="category"/>
                <field name="posts_count"/>
                <field name="last_scanned"/>
                <field name="is_active" widget="boolean_toggle"/>
            </tree>
        </field>
    </record>

    <!-- Premium Form View -->
    <record id="view_smart_radar_target_form" model="ir.ui.view">
        <field name="name">smart.radar.target.form</field>
        <field name="model">smart.radar.target</field>
        <field name="arch" type="xml">
            <form string="Managed Target">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object" name="action_view_posts" icon="fa-file-text-o" invisible="posts_count == 0">
                            <field string="المنح" name="posts_count" widget="statinfo"/>
                        </button>
                    </div>
                    <widget name="web_ribbon" title="موقوف" bg_color="text-bg-warning" invisible="is_active"/>
                    <widget name="web_ribbon" title="مُراقب ومُفعل" bg_color="text-bg-success" invisible="not is_active"/>
                    
                    <field name="image_1920" widget="image" class="oe_avatar" options="{'preview_image': 'image_128'}"/>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only" string="اسم الجهة (المنصة)"/>
                        <h1>
                            <field name="name" placeholder="Target Name (e.g., USAID)"/>
                        </h1>
                    </div>
                    
                    <group>
                        <group name="Identity" string="هوية الجهة">
                            <field name="handle" placeholder="e.g. @USAIDMiddleEast" widget="url"/>
                            <field name="category"/>
                        </group>
                        <group name="Engine Status" string="حالة نظام الرصد الذكي">
                            <field name="is_active" widget="boolean_toggle"/>
                            <field name="last_scanned" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_smart_radar_target" model="ir.actions.act_window">
        <field name="name">الجهات المستهدفة (Targets)</field>
        <field name="res_model">smart.radar.target</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="help" type="html">
          <p class="o_view_nocontent_smiling_face">
            أضف أول جهة مانحة أو منظمة للبدء!
          </p>
          <p>
            سيقوم النظام بمراقبة نشاطهم والتقاط المبادرات آلياً.
          </p>
        </field>
    </record>
</odoo>

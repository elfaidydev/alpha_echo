<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Top Level Menu -->
        <menuitem id="menu_smart_radar_root" name="Smart Radar" sequence="10" web_icon="smart_radar,static/description/icon.png"/>

        <!-- Dashboard Menu -->
        <record id="action_smart_radar_dashboard" model="ir.actions.client">
            <field name="name">Command Center</field>
            <field name="tag">smart_radar.dashboard</field>
        </record>
        <menuitem id="menu_smart_radar_dashboard" name="Dashboard" parent="menu_smart_radar_root" action="action_smart_radar_dashboard" sequence="10"/>

        <!-- Operational Menus -->
        <record id="action_smart_radar_post_client" model="ir.actions.client">
            <field name="name">Grants &amp; Posts Review</field>
            <field name="tag">smart_radar.posts_client_action</field>
        </record>
        <menuitem id="menu_smart_radar_posts" name="Grants &amp; Posts" parent="menu_smart_radar_root" action="action_smart_radar_post_client" sequence="20"/>
        <record id="action_smart_radar_targets_client" model="ir.actions.client">
            <field name="name">Monitored Targets</field>
            <field name="tag">smart_radar.targets_client_action</field>
        </record>
        <menuitem id="menu_smart_radar_targets" name="Monitored Targets" parent="menu_smart_radar_root" action="action_smart_radar_targets_client" sequence="30"/>

        <!-- Settings Menu -->
        <menuitem id="menu_smart_radar_settings_root" name="Configuration" parent="menu_smart_radar_root" sequence="90"/>
        
        <menuitem id="menu_smart_radar_client_config" name="System Settings" parent="menu_smart_radar_settings_root" action="action_smart_radar_config_settings" sequence="10"/>
    </data>
</odoo>

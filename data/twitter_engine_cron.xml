<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="ir_cron_twitter_smart_scraper" model="ir.cron">
            <field name="name">Alpha Echo: Smart Search Scraper (Chunked)</field>
            <field name="model_id" ref="model_twitter_scraper_engine"/>
            <field name="state">code</field>
            <field name="code">model.run_smart_scraper()</field>
            <!-- Alpha Echo Protocol (OR Query Edition): 30-min interval -->
            <!-- Cost target: ~$17-20/month for 12 groups (360 accounts) -->
            <!-- Each group is naturally hit every ~6 hours via round-robin -->
            <field name="interval_number">30</field>
            <field name="interval_type">minutes</field>
            <field name="numbercall">-1</field>
            <field name="active" eval="True"/>
        </record>
    </data>
</odoo>


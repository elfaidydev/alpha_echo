<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="alpha_echo.ConfigPage" owl="1">
        <div class="o_alpha_echo_config">
            <!-- Trap for Browser Autofill (Honeypot) -->
            <div style="position: absolute; left: -9999px; height: 1px; width: 1px; overflow: hidden;" aria-hidden="true">
                <input type="text" name="username_autofill_trap" value="trap" tabindex="-1"/>
                <input type="password" name="password_autofill_trap" value="trap" tabindex="-1"/>
            </div>
            
            <div class="sr-v4-dashboard px-4 py-2">
                
                <!-- Main Header -->
                <div class="sr-header-v4 mb-4">
                    <div class="header-right-side w-100 justify-content-center justify-content-md-start">
                        <div class="logo-box">
                            <i class="fa fa-sliders"/>
                        </div>
                        <div class="title-box">
                            <h1>الربط والإعدادات</h1>
                            <p class="subtitle">التحكم في مصادر البحث، الذكاء الاصطناعي، وربط حسابات النشر</p>
                        </div>
                    </div>
                </div>

                <div class="sr-unified-panel mt-3">
                    
                    <!-- Section 1: AI Prompt & Keywords (Apify Filter) -->
                    <div class="sr-section-block">
                        <div class="sr-section-title">
                            <i class="fa fa-magic text-primary me-2"/> البحث والذكاء الاصطناعي
                        </div>
                        <div class="row g-4 g-xl-5">
                            <div class="col-xl-7 col-lg-12">
                                <label class="sr-label mb-2">تعليمات الذكاء الاصطناعي (AI Prompt)</label>
                                <p class="text-muted small mb-3">قم بكتابة التعليمات التي سيتبعها الذكاء الاصطناعي عند إعادة صياغة التغريدات لتناسب أهدافك.</p>
                                <textarea class="form-control sr-prompt-box" t-model="config.custom_ai_instructions" t-on-input="(ev) => this.onFieldChange('custom_ai_instructions', ev.target.value)" placeholder="مثال: لخص التغريدات التقنية دي واكتبها كخبر صحفي بسيط وواضح بأسلوب احترافي..."></textarea>
                            </div>

                            <div class="col-xl-5 col-lg-12">
                                <label class="sr-label mb-2">الكلمات المفتاحية للبحث والفترة</label>
                                <p class="text-muted small mb-3">حدد الكلمات المفتاحية الأساسية للبحث؛ سيتم تجاهل التغريدات التي لا تحتوي عليها لترشيد استهلاك الرصيد.</p>
                                <div class="sr-tag-container mb-3">
                                    <t t-foreach="keywords" t-as="keyword" t-key="keyword">
                                        <span class="sr-tag">
                                            <t t-esc="keyword"/>
                                            <i class="fa fa-times-circle ms-1" t-on-click="() => this.removeKeyword(keyword)"/>
                                        </span>
                                    </t>
                                    <input type="text" autocomplete="new-password" class="sr-tag-input" placeholder="اكتب واضغط Enter..." t-model="state.ui.newKeyword" t-on-keydown="addKeyword"/>
                                </div>
                                <div class="alert alert-info py-2 px-3 border-0 bg-light" role="alert">
                                    <i class="fa fa-info-circle ms-2 text-primary"/>
                                    <small class="text-dark font-weight-bold">عدد الفلاتر النشطة حالياً: <b class="text-primary"><t t-esc="keywords.length"/></b> فلاتر.</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="sr-divider"/>

                    <!-- Section 2: Operation Frequency & Autopilot Limits -->
                    <div class="sr-section-block">
                        <div class="row g-4 g-xl-5 align-items-center">
                            
                            <!-- Sliders -->
                            <div class="col-xl-8 col-lg-12 border-end-xl pr-xl-5">
                                <div class="sr-section-title">
                                    <i class="fa fa-dashboard text-warning me-2"/> سرعة العمل وحدود النشر
                                </div>
                                
                            <div class="sr-config-card-v4 mb-4">
                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-3">
                                    <div class="d-flex align-items-center text-start mb-3 mb-md-0">
                                        <div class="icon-circle bg-indigo-subtle text-indigo me-3">
                                            <i class="fa fa-clock-o"/>
                                        </div>
                                        <div class="text-start">
                                            <h5 class="mb-0 fw-boldest text-dark">سرعة البحث عن محتوى جديد</h5>
                                            <p class="text-muted small mb-0 font-weight-bold">اختر الفاصل الزمني بين كل عملية فحص للبحث عن محتوى جديد.</p>
                                        </div>
                                    </div>
                                    <div class="badge-v4 glass-dark me-auto me-md-0">
                                        <t t-set="total_mins" t-value="config.scraping_interval || 180"/>
                                        <t t-set="hrs" t-value="Math.floor(total_mins / 60)"/>
                                        <t t-set="mins" t-value="total_mins % 60"/>
                                        <t t-esc="hrs"/> ساعة <t t-if="mins > 0">و <t t-esc="mins"/> دقيقة</t>
                                    </div>
                                </div>
                                <input type="range" class="form-range custom-v4-range primary-range" 
                                       min="5" max="2880" step="5" 
                                       t-att-value="config.scraping_interval || 180"
                                       t-on-input="onScrapingIntervalInput"
                                       t-att-style="'--fill-percent: ' + getScrapingIntervalPercent() + '%'"/>
                                <div class="d-flex justify-content-between mt-2 text-start">
                                    <span class="range-info-v4 text-dark font-weight-bold"><i class="fa fa-info-circle me-2 text-indigo"/> سرعة البحث الحالية: <strong><t t-esc="config.scraping_interval || 180"/> دقيقة</strong></span>
                                    <span class="range-limit-v4 text-muted small font-weight-bold">الحد الأدنى: 5 د | الأقصى: 48 ساعة</span>
                                </div>
                            </div>

                            <div class="sr-config-card-v4">
                                <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-3">
                                    <div class="d-flex align-items-center text-start mb-3 mb-md-0">
                                        <div class="icon-circle bg-emerald-subtle text-emerald me-3">
                                            <i class="fa fa-paper-plane-o"/>
                                        </div>
                                        <div class="text-start">
                                            <h5 class="mb-0 fw-boldest text-dark">الحد الأقصى للنشر في اليوم</h5>
                                            <p class="text-muted small mb-0 font-weight-bold">تحكم في عدد المنشورات اليومية لتجنب الحظر أو إزعاج المتابعين.</p>
                                        </div>
                                    </div>
                                    <div t-att-class="'badge-v4 me-auto me-md-0 ' + (config.max_posts_per_day == 100 ? 'glass-emerald' : 'glass-dark')">
                                        <t t-if="config.max_posts_per_day == 100">وضعية النشر المفتوح ∞</t>
                                        <t t-else="">بحد أقصى <t t-esc="config.max_posts_per_day"/> منشور / يوم</t>
                                    </div>
                                </div>
                                <input type="range" class="form-range custom-v4-range secondary-range" 
                                       min="0" max="100" step="1" 
                                       t-att-value="config.max_posts_per_day"
                                       t-on-input="onMaxPostsInput"
                                       t-att-style="'--fill-percent: ' + getMaxPostsPercent() + '%'"/>
                                <div class="d-flex justify-content-between mt-2 text-start">
                                    <span class="range-info-v4 text-dark font-weight-bold">
                                        <i class="fa fa-info-circle me-2 text-emerald"/> 
                                        <t t-if="config.max_posts_per_day == 100">
                                            نظام الرصد سيعمل بكامل طاقته في وضعية النشر المفتوح.
                                        </t>
                                        <t t-else="">
                                            سيتوقف النشر تلقائياً عند الوصول لـ <t t-esc="config.max_posts_per_day"/> تغريدة.
                                        </t>
                                    </span>
                                </div>
                            </div>
                            </div>
                            
                            <!-- Auto Publish Toggle -->
                            <div class="col-xl-4 col-lg-12 pl-xl-5 text-center">
                                <div class="auto-publish-card p-4 rounded-4" t-att-class="config.auto_approve_drafts ? 'active-publish' : 'inactive-publish'">
                                    <div class="icon-pulse mb-3">
                                        <i t-att-class="'fa fa-rocket fa-2x ' + (config.auto_approve_drafts ? 'text-success' : 'text-muted')"/>
                                    </div>
                                    <h5 class="font-weight-bold mb-2">النشر التلقائي المباشر</h5>
                                    <p class="small mb-4 text-muted">عند تفعيل هذا الخيار، سيقوم النظام بنشر المحتوى المعالج فوراً دون الحاجة لمراجعتك المسبقة.</p>
                                    
                                    <div class="fancy-auto-switch mx-auto text-center" style="width: fit-content;">
                                        <div class="form-check form-switch p-0 m-0">
                                            <input class="form-check-input ms-0 me-0" style="width: 4em; height: 2em; cursor:pointer;" type="checkbox" id="autoPublishMasterToggle" t-model="config.auto_approve_drafts" t-on-change="(ev) => this.onFieldChange('auto_approve_drafts', ev.target.checked)"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>

                    <hr class="sr-divider"/>

                    <!-- Section 3: Integrations (X & Odoo) -->
                    <div class="sr-section-block">
                        <div class="sr-section-title">
                            <i class="fa fa-link text-primary me-2"/> حسابات النشر والربط
                        </div>
                        <div class="row g-4">
                            
                            <!-- X (Twitter) Integration -->
                            <div class="col-xl-7 col-lg-12">
                                <div class="integration-card h-100 p-4 rounded-4 bg-light border-0">
                                    <div class="d-flex justify-content-between align-items-start mb-4">
                                        <h6 class="font-weight-bold d-flex align-items-center m-0" style="color: #0f1419; font-size:16px;">
                                            <svg viewBox="0 0 24 24" aria-hidden="true" class="r-18jsvk2 r-4qtqp9 r-yyyyoo r-16y2uox r-lwhw9o r-color-900 ms-2" style="width: 24px; height: 24px; fill:currentColor;"><g><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.007 3.56H5.022z"></path></g></svg>
                                            ربط حساب تويتر (منصة X)
                                        </h6>
                                        <span class="badge rounded-pill" t-att-class="isTwitterConnected ? 'bg-success' : 'bg-warning text-dark'">
                                            <t t-if="isTwitterConnected"><i class="fa fa-check me-1"/> متصل وحصري</t>
                                            <t t-else=""><i class="fa fa-plug me-1"/> قيد الانتظار</t>
                                        </span>
                                    </div>

                                    <!-- Logic: If connected, show profile card. If NOT, show inputs. -->
                                    <t t-if="isTwitterConnected">
                                        <div class="sr-connected-card p-3 rounded-4 d-flex align-items-center justify-content-between" style="background: rgba(29, 161, 242, 0.05); border: 1px solid rgba(29, 161, 242, 0.2);">
                                            <div class="d-flex align-items-center">
                                                <div class="me-3 position-relative">
                                                    <t t-if="config.twitterUser and config.twitterUser.profile_image_url">
                                                        <img t-att-src="config.twitterUser.profile_image_url" class="rounded-circle border border-2 border-white shadow-sm" style="width: 64px; height: 64px;"/>
                                                    </t>
                                                    <t t-else="">
                                                        <div class="rounded-circle bg-dark text-white d-flex justify-content-center align-items-center shadow-sm" style="width: 64px; height: 64px; font-size: 28px;">
                                                            <i class="fa fa-twitter"/>
                                                        </div>
                                                    </t>
                                                    <div class="position-absolute bottom-0 end-0 bg-primary rounded-circle d-flex align-items-center justify-content-center border border-2 border-white" style="width: 20px; height: 20px;">
                                                        <i class="fa fa-twitter text-white" style="font-size: 10px;"/>
                                                    </div>
                                                </div>
                                                <div class="text-start">
                                                    <h5 class="mb-0 fw-bold"><t t-esc="config.twitterUser ? config.twitterUser.name : 'الحساب المربوط'"/></h5>
                                                    <p class="text-muted mb-0">@<t t-esc="config.twitterUser ? config.twitterUser.username : 'Account'"/></p>
                                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill mt-1">متصل ومفعل</span>
                                                </div>
                                            </div>
                                            <button class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold" t-on-click="disconnectTwitter">
                                                <i class="fa fa-unlink me-1"/> قطع الارتباط
                                            </button>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="row g-3">
                                            <div class="col-md-6 text-start">
                                                <label class="sr-label x-small mb-1">API Key</label>
                                                <div class="input-group input-group-sm">
                                                    <input t-att-type="state.ui.showTwitterApiKey ? 'text' : 'password'" autocomplete="new-password" class="form-control" t-model="config.x_api_key" t-on-input="(ev) => this.onFieldChange('x_api_key', ev.target.value)"/>
                                                    <button class="btn btn-outline-secondary" type="button" t-on-click="() => this.toggleVisibility('showTwitterApiKey')">
                                                        <i t-attf-class="fa {{ state.ui.showTwitterApiKey ? 'fa-eye-slash' : 'fa-eye' }}"/>
                                                    </button>
                                                </div>
                                            </div>
                                            <div class="col-md-6 text-start">
                                                <label class="sr-label x-small mb-1">API Secret</label>
                                                <div class="input-group input-group-sm">
                                                    <input t-att-type="state.ui.showTwitterApiSecret ? 'text' : 'password'" autocomplete="new-password" class="form-control" t-model="config.x_api_secret" t-on-input="(ev) => this.onFieldChange('x_api_secret', ev.target.value)"/>
                                                    <button class="btn btn-outline-secondary" type="button" t-on-click="() => this.toggleVisibility('showTwitterApiSecret')">
                                                        <i t-attf-class="fa {{ state.ui.showTwitterApiSecret ? 'fa-eye-slash' : 'fa-eye' }}"/>
                                                    </button>
                                                </div>
                                            </div>
                                            <div class="col-md-6 text-start">
                                                <label class="sr-label x-small mb-1">Access Token</label>
                                                <div class="input-group input-group-sm">
                                                    <input t-att-type="state.ui.showTwitterAccessToken ? 'text' : 'password'" autocomplete="new-password" class="form-control" t-model="config.x_access_token" t-on-input="(ev) => this.onFieldChange('x_access_token', ev.target.value)"/>
                                                    <button class="btn btn-outline-secondary" type="button" t-on-click="() => this.toggleVisibility('showTwitterAccessToken')">
                                                        <i t-attf-class="fa {{ state.ui.showTwitterAccessToken ? 'fa-eye-slash' : 'fa-eye' }}"/>
                                                    </button>
                                                </div>
                                            </div>
                                            <div class="col-md-6 text-start">
                                                <label class="sr-label x-small mb-1">Access Secret</label>
                                                <div class="input-group input-group-sm">
                                                    <input t-att-type="state.ui.showTwitterAccessSecret ? 'text' : 'password'" autocomplete="new-password" class="form-control" t-model="config.x_access_token_secret" t-on-input="(ev) => this.onFieldChange('x_access_token_secret', ev.target.value)"/>
                                                    <button class="btn btn-outline-secondary" type="button" t-on-click="() => this.toggleVisibility('showTwitterAccessSecret')">
                                                        <i t-attf-class="fa {{ state.ui.showTwitterAccessSecret ? 'fa-eye-slash' : 'fa-eye' }}"/>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        <div class="d-flex flex-column flex-md-row align-items-stretch align-items-md-center mt-3 gap-3">
                                            <div class="alert alert-warning mb-0 p-2 small border-0 flex-grow-1 text-center text-md-end">
                                                <i class="fa fa-exclamation-triangle me-2"/> يرجى إدخال كافة المفاتيح ثم الضغط على "ربط الحساب الآن".
                                            </div>
                                            <button class="btn btn-primary font-weight-bold rounded-pill px-4 py-2 w-100 w-md-auto" t-att-disabled="!config.isFullyConfigured" t-on-click="saveConfig">
                                                <i class="fa fa-link me-2"/> ربط الحساب الآن
                                            </button>
                                        </div>
                                    </t>
                                </div>
                            </div>

                            <!-- Odoo Website Integration -->
                            <div class="col-xl-5 col-lg-12">
                                <div class="integration-card h-100 p-4 rounded-4 bg-light border-0">
                                    <div class="d-flex justify-content-between align-items-start mb-4">
                                        <h6 class="font-weight-bold d-flex align-items-center m-0" style="color: var(--v4-indigo); font-size:16px;">
                                            <i class="fa fa-globe me-2 fa-lg"/>
                                            النشر التلقائي على مدونة الموقع
                                        </h6>
                                        <span class="badge rounded-pill" t-att-class="isOdooBlogConnected ? 'bg-success' : 'bg-secondary'">
                                            <t t-if="isOdooBlogConnected">الحالة: متصل</t>
                                            <t t-else="">الحالة: معطل</t>
                                        </span>
                                    </div>
                                    
                                    <p class="text-muted small mb-4">عند إضافة معرف المدونة (Blog ID)، سيقوم النظام بتحويل التغريدات إلى مقالات متكاملة ونشرها تلقائياً على مدونتك لتحسين ظهورك في محركات البحث (SEO).</p>
                                    
                                    <div class="form-group mb-0">
                                        <label class="sr-label mb-2">رقم المدونة في الموقع (Odoo Blog ID)</label>
                                        <input type="number" class="form-control w-100" placeholder="مثال: 1" t-model="config.odoo_blog_id" t-on-input="(ev) => this.onFieldChange('odoo_blog_id', ev.target.value)"/>
                                    </div>
                                </div>
                            </div>
                            
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </t>
</templates>


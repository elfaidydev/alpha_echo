<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="alpha_echo.ConfigPage" owl="1">
        <div class="o_alpha_echo_config">
            <!-- Trap for Browser Autofill (Honeypot) -->
            <div style="position: absolute; left: -9999px; height: 1px; width: 1px; overflow: hidden;" aria-hidden="true">
                <input type="text" name="username_autofill_trap" value="trap" tabindex="-1"/>
                <input type="password" name="password_autofill_trap" value="trap" tabindex="-1"/>
            </div>
            
            <div class="sr-v4-dashboard px-4 py-2">
                
                <!-- Main Header -->
                <div class="sr-header-v4 mb-4">
                    <div class="header-right-side w-100 justify-content-center justify-content-md-start">
                        <div class="logo-box">
                            <i class="fa fa-sliders"/>
                        </div>
                        <div class="title-box">
                            <h1>Settings &amp; Configuration</h1>
                            <p class="subtitle">Manage search sources, AI engine, and publishing account integrations</p>
                        </div>
                    </div>
                </div>

                <div class="sr-unified-panel mt-3">
                    
                    <!-- Section 1: AI Prompt & X List ID -->
                    <div class="sr-section-block">
                        <div class="sr-section-title">
                            <i class="fa fa-magic"/>
                            Search &amp; AI
                        </div>
                        <div class="row g-4 g-xl-5">
                            <div class="col-xl-7 col-lg-12">
                                <label class="sr-label mb-2">AI Instructions (System Prompt)</label>
                                <p class="text-muted small mb-3">Write what the AI should look for and how to format the output. If a tweet doesn't match, the AI must return: <strong>SKIP_NOT_RELEVANT</strong></p>
                                <textarea class="form-control sr-prompt-box" t-model="config.custom_ai_instructions" t-on-input="(ev) => this.onFieldChange('custom_ai_instructions', ev.target.value)" placeholder="e.g. If the tweet announces an open grant, rewrite it as a professional post. Otherwise return: SKIP_NOT_RELEVANT"></textarea>
                            </div>

                            <div class="col-xl-5 col-lg-12">
                                <label class="sr-label mb-2">X List (ID or URL)</label>
                                <p class="text-muted small mb-3">Paste the numeric ID or the full URL of your X List. e.g: <strong>https://x.com/i/lists/123456...</strong></p>
                                <div class="d-flex gap-2">
                                    <input type="text" class="form-control" t-model="config.x_list_id" t-on-input="(ev) => this.onFieldChange('x_list_id', ev.target.value)" placeholder="e.g. https://x.com/i/lists/1234567890123456789"/>
                                </div>
                                
                                <div class="mt-4 p-3 border rounded bg-light border-primary-subtle">
                                    <h6 class="fw-bold mb-2 text-primary"><i class="fa fa-user-secret me-2"/>X Reader Account (Cookies)</h6>
                                    <p class="text-muted x-small mb-3" style="font-size: 0.8rem">These cookies are used by the scraper to read the list. They can belong to a different account than your publishing account.</p>
                                    <div class="row g-2">
                                        <div class="col-12 text-start">
                                            <label class="sr-label x-small mb-1"><i class="fa fa-cookie me-1"/>auth_token</label>
                                            <div class="input-group input-group-sm">
                                                <input t-att-type="state.ui.showTwitterAuthToken ? 'text' : 'password'" autocomplete="new-password" class="form-control" t-model="config.x_auth_token" t-on-input="(ev) => this.onFieldChange('x_auth_token', ev.target.value)"/>
                                                <button class="btn btn-outline-secondary" type="button" t-on-click="() => this.toggleVisibility('showTwitterAuthToken')">
                                                    <i t-attf-class="fa {{ state.ui.showTwitterAuthToken ? 'fa-eye-slash' : 'fa-eye' }}"/>
                                                </button>
                                            </div>
                                        </div>
                                        <div class="col-12 text-start mt-2">
                                            <label class="sr-label x-small mb-1"><i class="fa fa-cookie me-1"/>ct0</label>
                                            <div class="input-group input-group-sm">
                                                <input t-att-type="state.ui.showTwitterCt0 ? 'text' : 'password'" autocomplete="new-password" class="form-control" t-model="config.x_ct0" t-on-input="(ev) => this.onFieldChange('x_ct0', ev.target.value)"/>
                                                <button class="btn btn-outline-secondary" type="button" t-on-click="() => this.toggleVisibility('showTwitterCt0')">
                                                    <i t-attf-class="fa {{ state.ui.showTwitterCt0 ? 'fa-eye-slash' : 'fa-eye' }}"/>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div t-if="config.x_list_id" class="mt-2 d-flex align-items-center gap-2">
                                    <span class="badge rounded-pill bg-primary-subtle text-primary border border-primary-subtle px-3 py-2">
                                        <i class="fa fa-users me-1"/>
                                        <t t-esc="config.targets_count"/> Monitored Accounts
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="sr-divider"/>

                    <!-- Section 2: Auto-Publish Toggle -->
                    <div class="sr-section-block">
                        <div class="sr-section-title">
                            <i class="fa fa-dashboard"/>
                            Publishing Settings
                        </div>
                        <div class="row g-4 align-items-stretch">

                            <!-- Info Card: Scan Interval (hardcoded) -->
                            <div class="col-xl-4 col-lg-12">
                                <div class="sr-config-card-v4 h-100 p-4 rounded-4 bg-light border-0 d-flex flex-column align-items-center justify-content-center text-center">
                                    <div class="icon-circle bg-indigo-subtle text-indigo mb-3" style="width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                                        <i class="fa fa-clock-o fa-lg"/>
                                    </div>
                                    <h5 class="fw-bold mb-1">Scan Frequency</h5>
                                    <p class="text-muted small mb-3">Fixed interval between each X List scan.</p>
                                    <div class="badge-v4 glass-dark fs-5 px-4 py-2 rounded-pill fw-bold">
                                        Every 90 Minutes
                                    </div>
                                    <small class="text-muted mt-2"><i class="fa fa-lock me-1"/>Fixed — not configurable</small>
                                </div>
                            </div>

                            <!-- Info Card: Max Posts/Day (hardcoded) -->
                            <div class="col-xl-4 col-lg-12">
                                <div class="sr-config-card-v4 h-100 p-4 rounded-4 bg-light border-0 d-flex flex-column align-items-center justify-content-center text-center">
                                    <div class="icon-circle bg-emerald-subtle text-emerald mb-3" style="width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;">
                                        <i class="fa fa-paper-plane-o fa-lg"/>
                                    </div>
                                    <h5 class="fw-bold mb-1">Daily Post Cap</h5>
                                    <p class="text-muted small mb-3">Hard limit to protect your account.</p>
                                    <div class="badge-v4 glass-emerald fs-5 px-4 py-2 rounded-pill fw-bold">
                                        Max 300 / Day
                                    </div>
                                    <small class="text-muted mt-2"><i class="fa fa-lock me-1"/>Fixed — not configurable</small>
                                </div>
                            </div>

                            <!-- Auto-Publish Toggle -->
                            <div class="col-xl-4 col-lg-12 text-center">
                                <div class="auto-publish-card h-100 p-4 rounded-4" t-att-class="config.auto_approve_drafts ? 'active-publish' : 'inactive-publish'">
                                    <div class="icon-pulse mb-3">
                                        <i t-att-class="'fa fa-rocket fa-2x ' + (config.auto_approve_drafts ? 'text-success' : 'text-muted')"/>
                                    </div>
                                    <h5 class="font-weight-bold mb-2">Auto-Publish</h5>
                                    <p class="small mb-4 text-muted">When enabled, AI content is published immediately without manual review.</p>
                                    <div class="fancy-auto-switch mx-auto text-center" style="width: fit-content;">
                                        <div class="form-check form-switch p-0 m-0">
                                            <input class="form-check-input ms-0 me-0" style="width: 4em; height: 2em; cursor:pointer;" type="checkbox" id="autoPublishMasterToggle" t-model="config.auto_approve_drafts" t-on-change="(ev) => this.onFieldChange('auto_approve_drafts', ev.target.checked)"/>
                                        </div>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>


                    <hr class="sr-divider"/>
                    
                    <!-- Section 3: AI Service Credentials -->
                    <div class="sr-section-block">
                        <div class="sr-section-title">
                            <i class="fa fa-key"/>
                            AI Service Credentials
                        </div>
                        <p class="text-muted small mb-4">These keys connect the tracking engine to AI processing and automated scraping services. They are stored securely and masked by default.</p>
                        <div class="row g-4">
                            <!-- OpenAI API Key -->
                            <div class="col-md-6 text-start">
                                <label class="sr-label mb-2"><i class="fa fa-microchip me-1"/> OpenAI API Key</label>
                                <div class="input-group">
                                    <input type="password" autocomplete="new-password" class="form-control" t-model="config.openai_api_key" t-on-input="(ev) => this.onFieldChange('openai_api_key', ev.target.value)" placeholder="sk-..."/>
                                </div>
                                <small class="text-muted mt-1 d-block">Required for content analysis and formulation.</small>
                            </div>
                            
                            <!-- Apify API Token -->
                            <div class="col-md-6 text-start">
                                <label class="sr-label mb-2"><i class="fa fa-cloud me-1"/> Apify API Token</label>
                                <div class="input-group">
                                    <input type="password" autocomplete="new-password" class="form-control" t-model="config.apify_token" t-on-input="(ev) => this.onFieldChange('apify_token', ev.target.value)" placeholder="apify_api_..."/>
                                </div>
                                <small class="text-muted mt-1 d-block">Required for discovering accounts and fetching posts.</small>
                            </div>
                        </div>
                    </div>

                    <hr class="sr-divider"/>

                    <!-- Section 4: Integrations (X & Odoo) -->
                    <div class="sr-section-block">
                        <div class="sr-section-title">
                            <i class="fa fa-link"/>
                            Publishing &amp; Integration Accounts
                        </div>
                        <div class="row g-4">
                            
                            <!-- X (Twitter) Integration -->
                            <div class="col-xl-7 col-lg-12">
                                <div class="integration-card h-100 p-4 rounded-4 bg-light border-0">
                                    <div class="d-flex justify-content-between align-items-start mb-4">
                                        <h6 class="font-weight-bold d-flex align-items-center gap-2 m-0" style="color: #0f1419; font-size:16px;">
                                            <svg viewBox="0 0 24 24" aria-hidden="true" class="r-18jsvk2 r-4qtqp9 r-yyyyoo r-16y2uox r-lwhw9o r-color-900" style="width: 24px; height: 24px; fill:currentColor;"><g><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.007 3.56H5.022z"></path></g></svg>
                                            Link X Account
                                        </h6>
                                        <span class="badge rounded-pill" t-att-class="isTwitterConnected ? 'bg-success' : 'bg-warning text-dark'">
                                            <t t-if="isTwitterConnected">
                                                <i class="fa fa-check me-1"/>
                                                Connected
                                            </t>
                                            <t t-else="">
                                                <i class="fa fa-plug me-1"/>
                                                Pending
                                            </t>
                                        </span>
                                    </div>

                                    <!-- Logic: If connected, show profile card. If NOT, show inputs. -->
                                    <t t-if="isTwitterConnected">
                                        <div class="sr-connected-card p-3 rounded-4 d-flex align-items-center justify-content-between" style="background: rgba(29, 161, 242, 0.05); border: 1px solid rgba(29, 161, 242, 0.2);">
                                            <div class="d-flex align-items-center">
                                                <div class="me-3 position-relative">
                                                    <t t-if="config.twitterUser and config.twitterUser.profile_image_url">
                                                        <img t-att-src="config.twitterUser.profile_image_url" class="rounded-circle border border-2 border-white shadow-sm" style="width: 64px; height: 64px;"/>
                                                    </t>
                                                    <t t-else="">
                                                        <div class="rounded-circle bg-dark text-white d-flex justify-content-center align-items-center shadow-sm" style="width: 64px; height: 64px; font-size: 28px;">
                                                            <i class="fa fa-twitter"/>
                                                        </div>
                                                    </t>
                                                    <div class="position-absolute bottom-0 end-0 bg-dark rounded-circle d-flex align-items-center justify-content-center border border-2 border-white" style="width: 20px; height: 20px;">
                                                        <svg viewBox="0 0 24 24" style="width:10px;height:10px;fill:white;"><g><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.007 3.56H5.022z"/></g></svg>
                                                    </div>
                                                </div>
                                                <div class="text-start">
                                                    <h5 class="mb-0 fw-bold"><t t-esc="this.getTwitterName()"/></h5>
                                                    <p class="text-muted mb-0">@<t t-esc="this.getTwitterUsername()"/></p>
                                                    <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill mt-1">
                                                        Connected &amp; Active
                                                    </span>
                                                </div>
                                            </div>
                                            <button class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold" t-on-click="disconnectTwitter">
                                                <i class="fa fa-unlink me-1"/>
                                                Disconnect
                                            </button>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="row g-3">
                                            <div class="col-md-6 text-start">
                                                <label class="sr-label x-small mb-1">API Key</label>
                                                <div class="input-group input-group-sm">
                                                    <input t-att-type="state.ui.showTwitterApiKey ? 'text' : 'password'" autocomplete="new-password" class="form-control" t-model="config.x_api_key" t-on-input="(ev) => this.onFieldChange('x_api_key', ev.target.value)"/>
                                                    <button class="btn btn-outline-secondary" type="button" t-on-click="() => this.toggleVisibility('showTwitterApiKey')">
                                                        <i t-attf-class="fa {{ state.ui.showTwitterApiKey ? 'fa-eye-slash' : 'fa-eye' }}"/>
                                                    </button>
                                                </div>
                                            </div>
                                            <div class="col-md-6 text-start">
                                                <label class="sr-label x-small mb-1">API Secret</label>
                                                <div class="input-group input-group-sm">
                                                    <input t-att-type="state.ui.showTwitterApiSecret ? 'text' : 'password'" autocomplete="new-password" class="form-control" t-model="config.x_api_secret" t-on-input="(ev) => this.onFieldChange('x_api_secret', ev.target.value)"/>
                                                    <button class="btn btn-outline-secondary" type="button" t-on-click="() => this.toggleVisibility('showTwitterApiSecret')">
                                                        <i t-attf-class="fa {{ state.ui.showTwitterApiSecret ? 'fa-eye-slash' : 'fa-eye' }}"/>
                                                    </button>
                                                </div>
                                            </div>
                                            <div class="col-md-6 text-start">
                                                <label class="sr-label x-small mb-1">Access Token</label>
                                                <div class="input-group input-group-sm">
                                                    <input t-att-type="state.ui.showTwitterAccessToken ? 'text' : 'password'" autocomplete="new-password" class="form-control" t-model="config.x_access_token" t-on-input="(ev) => this.onFieldChange('x_access_token', ev.target.value)"/>
                                                    <button class="btn btn-outline-secondary" type="button" t-on-click="() => this.toggleVisibility('showTwitterAccessToken')">
                                                        <i t-attf-class="fa {{ state.ui.showTwitterAccessToken ? 'fa-eye-slash' : 'fa-eye' }}"/>
                                                    </button>
                                                </div>
                                            </div>
                                            <div class="col-md-6 text-start">
                                                <label class="sr-label x-small mb-1">Access Secret</label>
                                                <div class="input-group input-group-sm">
                                                    <input t-att-type="state.ui.showTwitterAccessSecret ? 'text' : 'password'" autocomplete="new-password" class="form-control" t-model="config.x_access_token_secret" t-on-input="(ev) => this.onFieldChange('x_access_token_secret', ev.target.value)"/>
                                                    <button class="btn btn-outline-secondary" type="button" t-on-click="() => this.toggleVisibility('showTwitterAccessSecret')">
                                                        <i t-attf-class="fa {{ state.ui.showTwitterAccessSecret ? 'fa-eye-slash' : 'fa-eye' }}"/>
                                                    </button>
                                                </div>
                                            </div>
                                            <!-- Cookies were moved to Search section -->
                                        </div>
                                        <div class="d-flex flex-column flex-md-row align-items-stretch align-items-md-center mt-3 gap-3">
                                            <div class="alert alert-warning mb-0 p-2 small border-0 flex-grow-1 text-start">
                                                <i class="fa fa-exclamation-triangle me-2"/>
                                                Please enter all keys then click "Connect Account".
                                            </div>
                                            <button class="btn btn-primary font-weight-bold rounded-pill px-4 py-2 w-100 w-md-auto" t-att-disabled="!config.isFullyConfigured" t-on-click="saveConfig">
                                                <i class="fa fa-link me-2"/>
                                                Connect Account
                                            </button>
                                        </div>
                                    </t>
                                </div>
                            </div>

                            <!-- Odoo Website Integration -->
                            <div class="col-xl-5 col-lg-12">
                                <div class="integration-card h-100 p-4 rounded-4 bg-light border-0">
                                    <div class="d-flex justify-content-between align-items-start mb-4">
                                        <h6 class="font-weight-bold d-flex align-items-center gap-2 m-0" style="color: var(--v4-indigo); font-size:16px;">
                                            <i class="fa fa-globe fa-lg"/>
                                            Auto-Publish to Website Blog
                                        </h6>
                                        <span class="badge rounded-pill" t-att-class="isOdooBlogConnected ? 'bg-success' : 'bg-secondary'">
                                            <t t-if="isOdooBlogConnected">
                                                Connected
                                            </t>
                                            <t t-else="">
                                                Disabled
                                            </t>
                                        </span>
                                    </div>
                                    
                                        <p class="text-muted small mb-4">When a Blog ID is provided, the system will convert tweets into full articles and publish them automatically to your blog, boosting your SEO visibility.</p>
                                    
                                    <div class="form-group mb-0">
                                        <label class="sr-label mb-2">
                                            Odoo Blog ID
                                        </label>
                                        <input type="number" class="form-control w-100" placeholder="e.g. 1" t-model="config.odoo_blog_id" t-on-input="(ev) => this.onFieldChange('odoo_blog_id', ev.target.value)"/>
                                    </div>
                                </div>
                            </div>
                            
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </t>
</templates>

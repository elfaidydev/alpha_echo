<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="alpha_echo.ConfigPage" owl="1">
        <div class="ae-config-page">
            <!-- Honeypot trap for browser autofill (hidden, never seen by users) -->
            <div class="ae-autofill-trap" aria-hidden="true">
                <input type="text"     name="username_autofill_trap" value="trap" tabindex="-1"/>
                <input type="password" name="password_autofill_trap" value="trap" tabindex="-1"/>
            </div>

            <div class="ae-container">

                <!-- ══ HEADER ════════════════════════════════════════════════════ -->
                <div class="ae-config-top-bar">
                    <div class="ae-config-title-side">
                        <div class="ae-logo-box"><i class="fa fa-sliders"/></div>
                        <div class="ae-title-text">
                            <h1><t t-esc="_t('Settings Center')"/></h1>
                            <p class="ae-subtitle"><t t-esc="_t('Configure AI intelligence and automated workflows')"/></p>
                        </div>
                    </div>

                    <!-- System Readiness Widget -->
                    <div class="ae-health-widget" t-att-class="configHealth.status">
                        <div class="ae-health-main">
                            <div class="ae-health-progress">
                                <svg viewBox="0 0 36 36" class="ae-circular-chart">
                                    <path class="ae-circle-bg" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
                                    <path class="ae-circle" t-att-stroke-dasharray="configHealth.percent + ', 100'" d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831"/>
                                </svg>
                                <span class="ae-health-num"><t t-esc="configHealth.percent"/>%</span>
                            </div>
                            <div class="ae-health-info">
                                <span class="ae-health-label"><t t-esc="_t('System Readiness')"/></span>
                                <span class="ae-health-desc">
                                    <t t-if="configHealth.status === 'optimal'"><t t-esc="_t('All systems operational')"/></t>
                                    <t t-elif="configHealth.status === 'partial'"><t t-esc="_t('Minor setup required')"/></t>
                                    <t t-else=""><t t-esc="_t('Critical setup missing')"/></t>
                                </span>
                            </div>
                        </div>
                        <div class="ae-health-details">
                            <div class="ae-h-item" t-att-class="{ready: configHealth.isAiReady}"><i class="fa fa-microchip"/></div>
                            <div class="ae-h-item" t-att-class="{ready: configHealth.isXLinked}"><i class="fa fa-twitter"/></div>
                            <div class="ae-h-item" t-att-class="{ready: configHealth.hasPrompt}"><i class="fa fa-magic"/></div>
                            <div class="ae-h-item" t-att-class="{ready: configHealth.hasList}"><i class="fa fa-list"/></div>
                        </div>
                    </div>

                    <button class="ae-btn-save-top" t-on-click="saveConfig" t-att-disabled="state.ui.isSaving">
                        <i t-attf-class="fa {{ state.ui.isSaving ? 'fa-spinner fa-spin' : 'fa-check' }}"/>
                        <span t-if="!state.ui.isSaving"><t t-esc="_t('Save Updates')"/></span>
                        <span t-else=""><t t-esc="_t('Saving...')"/></span>
                    </button>
                </div>

                <div class="ae-config-linear-layout">

                    <!-- ── SECTION 1: AI Intelligence ───────────────────────────── -->
                    <div class="ae-settings-section" id="intelligence">
                        <div class="ae-section-header-v2">
                            <div class="ae-icon-wrap"><i class="fa fa-magic"/></div>
                            <div class="ae-text-wrap">
                                <h3><t t-esc="_t('AI Intelligence &amp; Instructions')"/></h3>
                                <p><t t-esc="_t('Neural commands that govern how the AI identifies and rewrites content.')"/></p>
                            </div>
                        </div>

                        <div class="ae-glass-box p-4 mt-3">
                            <label class="ae-label"><t t-esc="_t('System Prompt Algorithm')"/></label>
                            <textarea class="ae-textarea-alt"
                                      t-model="config.custom_ai_instructions"
                                      t-on-input="(ev) => this.onFieldChange('custom_ai_instructions', ev.target.value)"
                                      t-att-placeholder="_t('e.g. Find technical news and rewrite it for developers...')"/>
                            <div class="ae-prompt-footer mt-2">
                                <i class="fa fa-info-circle"/>
                                <t t-esc="_t('Must include SKIP_NOT_RELEVANT instruction.')"/>
                            </div>
                        </div>

                        <!-- Source &amp; Identity Hub -->
                        <div class="ae-source-hub mt-4">
                            <div class="row g-4">
                                <!-- Discovery Source -->
                                <div class="col-lg-6">
                                    <div class="ae-hub-card">
                                        <div class="ae-hub-card-header">
                                            <div class="ae-glow-icon"><i class="fa fa-search-plus"/></div>
                                            <div class="ae-hub-card-text">
                                                <h4><t t-esc="_t('Content Discovery Source')"/></h4>
                                                <p><t t-esc="_t('The primary X List used for scanning.')"/></p>
                                            </div>
                                        </div>
                                        <div class="ae-hub-card-body">
                                            <div class="ae-input-group-v2">
                                                <label><t t-esc="_t('X List URL or identifier')"/></label>
                                                <div class="ae-input-with-icon">
                                                    <i class="fa fa-link"/>
                                                    <input type="text"
                                                           t-model="config.x_list_id"
                                                           t-on-input="(ev) => this.onFieldChange('x_list_id', ev.target.value)"
                                                           placeholder="https://x.com/i/lists/..."/>
                                                </div>
                                            </div>
                                            <div class="ae-source-status mt-3" t-if="config.targets_count">
                                                <span class="ae-badge-pulse">
                                                    <i class="fa fa-crosshairs"/>
                                                    <t t-esc="_t('Monitoring')"/> <t t-esc="config.targets_count"/> <t t-esc="_t('targets')"/>
                                                </span>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Reader Identity -->
                                <div class="col-lg-6">
                                    <div class="ae-hub-card auth-card">
                                        <div class="ae-hub-card-header">
                                            <div class="ae-glow-icon purple"><i class="fa fa-id-badge"/></div>
                                            <div class="ae-hub-card-text">
                                                <h4><t t-esc="_t('Reader Identity')"/></h4>
                                                <p><t t-esc="_t('Secure credentials for private list access.')"/></p>
                                            </div>
                                        </div>
                                        <div class="ae-hub-card-body">
                                            <div class="ae-credential-stack">
                                                <div class="ae-cred-field">
                                                    <div class="ae-cred-label">
                                                        <span>auth_token</span>
                                                        <span class="ae-secure-tag"><i class="fa fa-lock"/> <t t-esc="_t('Protected')"/></span>
                                                    </div>
                                                    <input type="password"
                                                           t-model="config.x_auth_token"
                                                           t-on-input="(ev) => this.onFieldChange('x_auth_token', ev.target.value)"
                                                           placeholder="••••••••••••••••"
                                                           autocomplete="off"/>
                                                </div>
                                                <div class="ae-cred-field mt-3">
                                                    <div class="ae-cred-label">
                                                        <span>ct0 (CSRF)</span>
                                                        <span class="ae-secure-tag"><i class="fa fa-lock"/> <t t-esc="_t('Protected')"/></span>
                                                    </div>
                                                    <input type="password"
                                                           t-model="config.x_ct0"
                                                           t-on-input="(ev) => this.onFieldChange('x_ct0', ev.target.value)"
                                                           placeholder="••••••••••••••••"
                                                           autocomplete="off"/>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ── SECTION 2: Automation ────────────────────────────────── -->
                    <div class="ae-settings-section mt-5" id="automation">
                        <div class="ae-section-header-v2">
                            <div class="ae-icon-wrap emerald"><i class="fa fa-dashboard"/></div>
                            <div class="ae-text-wrap">
                                <h3><t t-esc="_t('Engine Automation')"/></h3>
                                <p><t t-esc="_t('Configure the speed and capacity of your automated scanning.')"/></p>
                            </div>
                        </div>
                        <div class="ae-grid-2 mt-3">
                            <div class="ae-info-card-alt">
                                <div class="ae-card-icon"><i class="fa fa-refresh"/></div>
                                <div class="ae-card-data">
                                    <label><t t-esc="_t('Scan Interval')"/></label>
                                    <div class="ae-val"><t t-esc="_t('Every 90m')"/></div>
                                    <span class="ae-lock-tag"><i class="fa fa-lock"/> <t t-esc="_t('Fixed')"/></span>
                                </div>
                            </div>
                            <div class="ae-info-card-alt">
                                <div class="ae-card-icon"><i class="fa fa-bolt"/></div>
                                <div class="ae-card-data">
                                    <label><t t-esc="_t('Daily Post Capacity')"/></label>
                                    <div class="ae-val"><t t-esc="_t('300 Posts')"/></div>
                                    <span class="ae-lock-tag"><i class="fa fa-lock"/> <t t-esc="_t('Fixed')"/></span>
                                </div>
                            </div>
                        </div>
                        <div class="ae-glass-box p-4 mt-4">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h4 class="mb-1"><t t-esc="_t('Autonomous Publishing')"/></h4>
                                    <p class="ae-hint mb-0"><t t-esc="_t('AI content will go live immediately without human intervention.')"/></p>
                                </div>
                                <div class="ae-fancy-switch">
                                    <input type="checkbox" id="autoPubMain"
                                           t-model="config.auto_approve_drafts"
                                           t-on-change="(ev) => this.onFieldChange('auto_approve_drafts', ev.target.checked)"/>
                                    <label for="autoPubMain"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ── SECTION 3: API Credentials ─────────────────────────── -->
                    <div class="ae-settings-section mt-5" id="credentials">
                        <div class="ae-section-header-v2">
                            <div class="ae-icon-wrap indigo"><i class="fa fa-key"/></div>
                            <div class="ae-text-wrap">
                                <h3><t t-esc="_t('API Service Channels')"/></h3>
                                <p><t t-esc="_t('Managed encrypted tokens for AI and scraping providers.')"/></p>
                            </div>
                        </div>
                        <div class="ae-v-gap-md mt-3">
                            <div class="ae-key-row">
                                <div class="ae-key-icon"><i class="fa fa-microchip"/></div>
                                <div class="ae-key-main">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <label class="mb-0"><t t-esc="_t('OpenAI Enterprise Key')"/></label>
                                        <span class="ae-secure-tag"><i class="fa fa-lock"/> <t t-esc="_t('Protected')"/></span>
                                    </div>
                                    <input type="password"
                                           t-model="config.openai_api_key"
                                           t-on-input="(ev) => this.onFieldChange('openai_api_key', ev.target.value)"
                                           placeholder="sk-••••••••••••"
                                           autocomplete="off"/>
                                </div>
                            </div>
                            <div class="ae-key-row mt-3">
                                <div class="ae-key-icon purple"><i class="fa fa-cloud"/></div>
                                <div class="ae-key-main">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <label class="mb-0"><t t-esc="_t('Apify Cloud Token')"/></label>
                                        <span class="ae-secure-tag"><i class="fa fa-lock"/> <t t-esc="_t('Protected')"/></span>
                                    </div>
                                    <input type="password"
                                           t-model="config.apify_token"
                                           t-on-input="(ev) => this.onFieldChange('apify_token', ev.target.value)"
                                           placeholder="apify_api_••••••••••••"
                                           autocomplete="off"/>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ── SECTION 4: Publishing Destinations ─────────────────── -->
                    <div class="ae-settings-section mt-5" id="accounts">
                        <div class="ae-section-header-v2">
                            <div class="ae-icon-wrap"><i class="fa fa-link"/></div>
                            <div class="ae-text-wrap">
                                <h3><t t-esc="_t('Publishing Destinations')"/></h3>
                                <p><t t-esc="_t('Connect where your content will be broadcasted.')"/></p>
                            </div>
                        </div>
                        <div class="row g-4 mt-1">
                            <!-- X Connection Hub -->
                            <div class="col-xl-7 col-lg-12">
                                <div class="ae-auth-hub-card x-cyber-theme">
                                    <div class="ae-hub-glow-bg"/>
                                    <div class="ae-auth-hub-header">
                                        <div class="ae-brand-box">
                                            <i class="fa fa-twitter"/>
                                            <div class="ae-brand-status" t-att-class="isTwitterConnected ? 'verified' : 'pending'">
                                                <i t-att-class="isTwitterConnected ? 'fa fa-check-circle' : 'fa fa-exclamation-circle'"/>
                                            </div>
                                        </div>
                                        <div class="ae-brand-info">
                                            <h4><t t-esc="_t('X Connection Hub')"/></h4>
                                            <p t-if="!isTwitterConnected"><t t-esc="_t('Authorize broadcasting to your X account.')"/></p>
                                            <p t-else=""><t t-esc="_t('Broadcast engine is active and verified.')"/></p>
                                        </div>
                                        <div class="ae-verified-badge" t-if="isTwitterConnected">
                                            <span><t t-esc="_t('LIVE')"/></span>
                                        </div>
                                    </div>

                                    <div class="ae-auth-hub-content mt-4">
                                        <t t-if="isTwitterConnected">
                                            <div class="ae-active-profile">
                                                <div class="ae-profile-main">
                                                    <div class="ae-avatar-wrapper">
                                                        <img t-if="config.twitterUser" t-att-src="config.twitterUser.profile_image_url" class="ae-acc-avatar"/>
                                                        <div class="ae-avatar-ring"/>
                                                    </div>
                                                    <div class="ae-acc-text">
                                                        <div class="ae-name-row">
                                                            <h5><t t-esc="this.getTwitterName()"/></h5>
                                                            <i class="fa fa-certificate text-primary ms-1"/>
                                                        </div>
                                                        <p>@<t t-esc="this.getTwitterUsername()"/></p>
                                                    </div>
                                                </div>
                                                <button class="ae-btn-unlink-minimal" t-on-click="disconnectTwitter">
                                                    <i class="fa fa-chain-broken"/> <t t-esc="_t('Terminate Session')"/>
                                                </button>
                                            </div>
                                        </t>
                                        <t t-else="">
                                            <div class="ae-auth-form-cyber">
                                                <div class="ae-cyber-group-label"><t t-esc="_t('Authentication Tokens')"/></div>
                                                <div class="ae-credential-grid mt-3">
                                                    <div class="ae-cyber-input-wrap">
                                                        <div class="ae-field-meta">
                                                            <label><t t-esc="_t('API Key')"/></label>
                                                            <span class="ae-secure-tag-mini"><i class="fa fa-lock"/></span>
                                                        </div>
                                                        <input type="password" t-model="config.x_api_key"
                                                               t-on-input="(ev) => this.onFieldChange('x_api_key', ev.target.value)"
                                                               placeholder="••••••••••••" autocomplete="off"/>
                                                    </div>
                                                    <div class="ae-cyber-input-wrap">
                                                        <div class="ae-field-meta">
                                                            <label><t t-esc="_t('API Secret')"/></label>
                                                            <span class="ae-secure-tag-mini"><i class="fa fa-lock"/></span>
                                                        </div>
                                                        <input type="password" t-model="config.x_api_secret"
                                                               t-on-input="(ev) => this.onFieldChange('x_api_secret', ev.target.value)"
                                                               placeholder="••••••••••••" autocomplete="off"/>
                                                    </div>
                                                    <div class="ae-cyber-input-wrap">
                                                        <div class="ae-field-meta">
                                                            <label><t t-esc="_t('Access Token')"/></label>
                                                            <span class="ae-secure-tag-mini"><i class="fa fa-lock"/></span>
                                                        </div>
                                                        <input type="password" t-model="config.x_access_token"
                                                               t-on-input="(ev) => this.onFieldChange('x_access_token', ev.target.value)"
                                                               placeholder="••••••••••••" autocomplete="off"/>
                                                    </div>
                                                    <div class="ae-cyber-input-wrap">
                                                        <div class="ae-field-meta">
                                                            <label><t t-esc="_t('Token Secret')"/></label>
                                                            <span class="ae-secure-tag-mini"><i class="fa fa-lock"/></span>
                                                        </div>
                                                        <input type="password" t-model="config.x_access_token_secret"
                                                               t-on-input="(ev) => this.onFieldChange('x_access_token_secret', ev.target.value)"
                                                               placeholder="••••••••••••" autocomplete="off"/>
                                                    </div>
                                                </div>
                                                <button class="ae-btn-cyber-authorize mt-4"
                                                        t-att-disabled="!config.isFullyConfigured"
                                                        t-on-click="saveConfig">
                                                    <i class="fa fa-shield"/> <t t-esc="_t('Authorize Broadcast Engine')"/>
                                                </button>
                                            </div>
                                        </t>
                                    </div>
                                </div>
                            </div>

                            <!-- Odoo Blog Channel -->
                            <div class="col-xl-5 col-lg-12">
                                <div class="ae-account-card odoo-theme">
                                    <div class="ae-acc-header">
                                        <div class="ae-acc-logo"><i class="fa fa-globe"/></div>
                                        <span class="ae-acc-status" t-att-class="isOdooBlogConnected ? 'online' : 'offline'">
                                            <t t-esc="_t('Blog')"/>
                                        </span>
                                    </div>
                                    <div class="ae-acc-setup mt-4">
                                        <label class="ae-label"><t t-esc="_t('Odoo Blog Channel ID')"/></label>
                                        <input type="number" class="ae-input-alt mt-2"
                                               t-model="config.odoo_blog_id"
                                               t-on-input="(ev) => this.onFieldChange('odoo_blog_id', ev.target.value)"
                                               placeholder="e.g. 1"/>
                                        <p class="ae-hint smaller mt-3"><t t-esc="_t('Leave empty to disable Odoo Website publishing.')"/></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </t>
</templates>

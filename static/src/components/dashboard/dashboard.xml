<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="alpha_echo.Dashboard" owl="1">
        <div class="o_alpha_echo_dashboard" t-ref="dashboardMain">
            <div class="sr-v4-dashboard">
                
                <div class="sr-header-v4">
                    <div class="header-right-side">
                        <div class="logo-box">
                            <i class="fa fa-braille"/>
                        </div>
                        <div class="title-box">
                            <h1><t t-esc="_t('Dashboard')"/></h1>
                            <p class="subtitle"><t t-esc="_t('Central interface for tracking, reformulating, and publishing content')"/></p>
                        </div>
                    </div>
                    <div class="header-left-side">
                        <div class="health-nav">
                            <span class="status-pulse"></span> <t t-esc="state.targets.length"/> <t t-esc="_t('monitored sources')"/>
                        </div>
                        <button class="btn-primary-v4" t-on-click="toggleTracking" t-att-class="{'paused': !state.isTracking}">
                            <i class="fa ms-2" t-att-class="state.isTracking ? 'fa-pause' : 'fa-play'"/>
                            <t t-esc="trackingBtnLabel"/>
                        </button>
                        <button class="btn-icon-v4" t-on-click="fetchLatest" title="Instant Sync">
                            <i class="fa fa-refresh" t-att-class="{'fa-spin': state.isLoading}"/>
                        </button>
                    </div>
                </div>

                <t t-if="!state.isOnboarded">
                    <div class="sr-onboarding-hero-v2">
                        <div class="onboarding-bg-blobs">
                            <div class="blob blob-1"></div>
                            <div class="blob blob-2"></div>
                        </div>
                        
                        <div class="onboarding-main">
                            <div class="onboarding-header">
                                <h2><t t-esc="_t('Welcome to')"/> <span class="text-gradient">Alpha Echo</span></h2>
                                <p><t t-esc="_t('Automate content harvesting, formulation, and publishing with AI. Follow these steps to begin.')"/></p>
                            </div>

                            <div class="onboarding-grid grid-4-steps">
                                <!-- Step 1: Twitter -->
                                <div t-attf-class="onboarding-card {{ state.config.twitterLinked ? 'completed' : 'pending' }}" t-on-click="openSettings">
                                    <div class="card-glow"></div>
                                    <div class="card-content">
                                        <div class="step-label">Step 1</div>
                                        <div class="step-main">
                                            <div class="step-icon">
                                                <i class="fa fa-twitter"/>
                                                <div t-if="state.config.twitterLinked" class="check-badge"><i class="fa fa-check"/></div>
                                            </div>
                                            <div class="step-info">
                                                <h4><t t-esc="_t('Link X (Twitter)')"/></h4>
                                                <p><t t-esc="_t('Authorize the system to publish via your account.')"/></p>
                                            </div>
                                        </div>
                                        <div class="step-footer mt-2 text-start">
                                            <span t-if="state.config.twitterLinked" class="status-done"><t t-esc="_t('Linked')"/> <i class="fa fa-check-circle me-1"/></span>
                                            <span t-else="" class="status-btn"><t t-esc="_t('Connect')"/> <i class="fa fa-link me-1"/></span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Step 2: AI Prompt -->
                                <t t-set="isPromptDone" t-value="state.config.custom_ai_instructions and state.config.custom_ai_instructions.length > 0"/>
                                <div t-attf-class="onboarding-card {{ isPromptDone ? 'completed' : 'pending' }}" t-on-click="openSettings">
                                    <div class="card-glow"></div>
                                    <div class="card-content">
                                        <div class="step-label">Step 2</div>
                                        <div class="step-main">
                                            <div class="step-icon">
                                                <i class="fa fa-magic"/>
                                                <div t-if="isPromptDone" class="check-badge"><i class="fa fa-check"/></div>
                                            </div>
                                            <div class="step-info">
                                                <h4><t t-esc="_t('AI Prompt')"/></h4>
                                                <p><t t-esc="_t('Define the tone and instructions for the AI engine.')"/></p>
                                            </div>
                                        </div>
                                        <div class="step-footer mt-2 text-start">
                                            <span t-if="isPromptDone" class="status-done"><t t-esc="_t('Set')"/> <i class="fa fa-check-circle me-1"/></span>
                                            <span t-else="" class="status-btn"><t t-esc="_t('Configure')"/> <i class="fa fa-edit me-1"/></span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Step 3: Keywords -->
                                <t t-set="isKeywordsDone" t-value="state.config.target_radar_focus and state.config.target_radar_focus.length > 0"/>
                                <div t-attf-class="onboarding-card {{ isKeywordsDone ? 'completed' : 'pending' }}" t-on-click="openSettings">
                                    <div class="card-glow"></div>
                                    <div class="card-content">
                                        <div class="step-label">Step 3</div>
                                        <div class="step-main">
                                            <div class="step-icon">
                                                <i class="fa fa-filter"/>
                                                <div t-if="isKeywordsDone" class="check-badge"><i class="fa fa-check"/></div>
                                            </div>
                                            <div class="step-info">
                                                <h4><t t-esc="_t('Search Keywords')"/></h4>
                                                <p><t t-esc="_t('Set primary filters for discovered content.')"/></p>
                                            </div>
                                        </div>
                                        <div class="step-footer mt-2 text-start">
                                            <span t-if="isKeywordsDone" class="status-done"><t t-esc="_t('Defined')"/> <i class="fa fa-check-circle me-1"/></span>
                                            <span t-else="" class="status-btn"><t t-esc="_t('Add Filters')"/> <i class="fa fa-plus-circle me-1"/></span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Step 4: Targets -->
                                <t t-set="isTargetsDone" t-value="state.targets.length > 0"/>
                                <div t-attf-class="onboarding-card {{ isTargetsDone ? 'completed' : 'pending' }}" t-on-click="openSettings">
                                    <div class="card-glow"></div>
                                    <div class="card-content">
                                        <div class="step-label">Step 4</div>
                                        <div class="step-main">
                                            <div class="step-icon">
                                                <i class="fa fa-crosshairs"/>
                                                <div t-if="isTargetsDone" class="check-badge"><i class="fa fa-check"/></div>
                                            </div>
                                            <div class="step-info">
                                                <h4><t t-esc="_t('Monitored Sources')"/></h4>
                                                <p><t t-esc="_t('Add the accounts the radar will track.')"/></p>
                                            </div>
                                        </div>
                                        <div class="step-footer mt-2 text-start">
                                            <span t-if="isTargetsDone" class="status-done">Added <t t-esc="state.targets.length"/> <i class="fa fa-check-circle me-1"/></span>
                                            <span t-else="" class="status-btn">Add Targets <i class="fa fa-plus me-1"/></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="onboarding-action">
                                <p class="helper-text">Need help? Read the <a href="#">Quick Start Guide</a></p>
                                <button class="sr-premium-btn" t-on-click="toggleTracking" t-att-disabled="!state.isOnboarded">
                                    <span>Activate Full Radar</span>
                                    <i class="fa fa-bolt"/>
                                </button>
                            </div>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <div class="sr-hero-card-v4">
                        <div class="hero-content">
                            <div class="ai-sparkle-v4"><i class="fa fa-magic"/></div>
                            <div class="hero-text">
                                <h2>Advanced exploration and analysis engine is active.</h2>
                                <p>
                                    Currently <strong><t t-esc="state.targets.length"/> certified sources</strong> are under real-time monitoring. Successfully discovered <strong><t t-esc="state.grantsDiscovered"/> new topics</strong> today. 
                                    AI has handled professional reformulation and content has been <strong>automatically and simultaneously</strong> published across official channels.
                                </p>
                            </div>
                        </div>
                        <div class="hero-curve-bg"></div>
                    </div>

                    <!-- Live Targets Radar Section -->
                    <div class="sr-radar-listening-v4">
                        <div class="listening-header">
                            <span><i class="fa fa-crosshairs ms-1"/> Live Target Map (Net of <t t-esc="state.targets.length"/>)</span>
                            <div class="sweep-animation"></div>
                        </div>
                        <div class="targets-marquee-container">
                            <div class="targets-marquee">
                                <t t-foreach="state.targets" t-as="target" t-key="target.id">
                                    <div class="target-pill"><span class="pulse-dot"></span> <t t-esc="target.name"/></div>
                                </t>
                                <t t-if="state.targets.length === 0">
                                    <div class="target-pill ghost"><i class="fa fa-plus ms-1"/> Searching for sources matching your criteria...</div>
                                </t>
                                <!-- Duplicate for infinite seamless scroll -->
                                <t t-foreach="state.targets" t-as="target" t-key="'dup_' + target.id">
                                    <div class="target-pill"><span class="pulse-dot"></span> <t t-esc="target.name"/></div>
                                </t>
                                <t t-if="state.targets.length === 0">
                                    <div class="target-pill ghost"><i class="fa fa-plus ms-1"/> Searching for sources matching your criteria...</div>
                                </t>
                            </div>
                        </div>
                    </div>

                <div class="sr-kpi-grid-v4">
                    <div class="kpi-card-v4">
                        <div class="kpi-top">
                            <div class="kpi-text">
                                <span class="kpi-title">New Content Discovered Today</span>
                                <div class="kpi-value"><t t-esc="state.grantsDiscovered"/></div>
                            </div>
                            <div class="kpi-icon blue"><i class="fa fa-search-plus"/></div>
                        </div>
                        <div class="kpi-chart sparkline"><canvas t-ref="sparkline1"></canvas></div>
                    </div>
                    
                    <div class="kpi-card-v4">
                        <div class="kpi-top">
                            <div class="kpi-text">
                                <span class="kpi-title">Publications (Website + X)</span>
                                <div class="kpi-value"><t t-esc="state.publishedToday"/></div>
                            </div>
                            <div class="kpi-icon emerald"><i class="fa fa-paper-plane"/></div>
                        </div>
                        <div class="kpi-chart sparkline"><canvas t-ref="sparkline2"></canvas></div>
                    </div>
                    
                    <div class="kpi-card-v4">
                        <div class="kpi-top">
                            <div class="kpi-text">
                                <span class="kpi-title">Monitored Source Accounts</span>
                                <div class="kpi-value"><t t-esc="state.monitoredAccounts"/> <span>sources</span></div>
                            </div>
                            <div class="kpi-icon indigo"><i class="fa fa-users"/></div>
                        </div>
                        <div class="kpi-chart sparkline">
                            <!-- Visual placeholder for steady constant line -->
                            <div style="height: 100%; border-bottom: 2px dashed #4f46e5; opacity: 0.2; transform: translateY(-15px);"></div>
                        </div>
                    </div>
                    
                    <div class="kpi-card-v4">
                        <div class="kpi-top">
                            <div class="kpi-text">
                                <span class="kpi-title">Formulation Prompt Accuracy</span>
                                <div class="kpi-value"><t t-esc="state.matchRate"/><span>%</span></div>
                            </div>
                            <div class="kpi-icon amber"><i class="fa fa-shield"/></div>
                        </div>
                        <div class="kpi-chart sparkline"><canvas t-ref="sparkline4"></canvas></div>
                    </div>
                </div>

                <div class="sr-main-grid-v4">
                    <div class="grid-primary">
                        <div class="charts-row">
                            <div class="chart-card-v4 w-65">
                                <div class="card-header">
                                    <h3>Content Flow Density by Time</h3>
                                    <span class="badge-soft">Live</span>
                                </div>
                                <div class="chart-container">
                                    <canvas t-ref="barChartCanvas"></canvas>
                                </div>
                            </div>
                            <div class="chart-card-v4 w-35">
                                <div class="card-header" style="margin-bottom: 8px;">
                                    <h3>Automated Publishing Routing</h3>
                                </div>
                                <div class="chart-container doughnut-container mt-2">
                                    <canvas t-ref="gaugeChartCanvas"></canvas>
                                    <div class="doughnut-center">
                                        <span class="d-number">100%</span>
                                        <span class="d-label">Dual Automation</span>
                                    </div>
                                </div>
                                <div class="custom-chart-legend">
                                    <div class="legend-item">
                                        <span class="legend-dot bg-indigo"></span>
                                        <span class="legend-text">Official Website (WordPress)</span>
                                    </div>
                                    <div class="legend-item">
                                        <span class="legend-dot bg-blue"></span>
                                        <span class="legend-text">X Account (Twitter)</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="feed-card-v4 mt-4">
                            <div class="card-header border-bottom">
                                <h3><i class="fa fa-bolt ms-2"/>Real-time Exploration Log</h3>
                            </div>
                            <div class="feed-list-v4">
                                <t t-if="state.feed.length === 0">
                                    <div class="empty-state">
                                        <i class="fa fa-microphone fa-2x mb-2 text-muted"/>
                                        <p>Exploration engine is performing deep scans of certified entities...</p>
                                    </div>
                                </t>
                                <t t-else="">
                                    <t t-foreach="state.feed" t-as="item" t-key="item.id">
                                        <div class="conversation-row fade-scale-up">
                                            
                                            <div class="chat-bubble raw-bubble">
                                                <div class="bubble-header">
                                                    <span><i class="fa fa-twitter ms-1"/> Raw Content from Source</span>
                                                    <span class="time"><t t-esc="item.time"/></span>
                                                </div>
                                                <div class="bubble-text"><t t-esc="item.original"/></div>
                                                <div class="source-tag">Source ID: <t t-esc="item.donor"/></div>
                                            </div>
                                            
                                            <div class="magic-arrow text-muted text-center" style="display: flex; flex-direction: column; gap: 8px;">
                                                <i class="fa fa-cogs" title="Smart Processing" style="font-size: 16px;"/>
                                                <i class="fa fa-angle-left" style="font-size: 24px;"/>
                                                <i class="fa fa-share-alt" title="Dual Publishing" style="font-size: 16px;"/>
                                            </div>

                                            <div class="chat-bubble ai-bubble">
                                                <div class="bubble-header ai-header">
                                                    <span><i class="fa fa-check-circle ms-1"/> Smart Processing &amp; Auto-Approval</span>
                                                    <div class="d-flex align-items-center">
                                                        <span class="conf-badge ms-2"><i class="fa fa-globe ms-1"/> On Website</span>
                                                        <span class="conf-badge ms-1" style="color: #1da1f2; background: #e8f5fe; border-color: #1da1f2;"><i class="fa fa-twitter ms-1"/> Published to X</span>
                                                    </div>
                                                </div>
                                                <div class="bubble-text"><t t-esc="item.rewritten"/></div>
                                                <div class="destination-tag"><a t-att-href="item.tweetLink" target="_blank" title="View Published Material">Live Verification <i class="fa fa-external-link"/></a></div>
                                            </div>
                                        </div>
                                    </t>
                                </t>
                            </div>
                        </div>
                    </div>

                    <div class="grid-secondary">
                        <div class="timeline-card-v4">
                            <div class="card-header border-bottom">
                                <h3><i class="fa fa-server ms-2"/>Real-time Operational Metrics</h3>
                            </div>
                            <div class="timeline-container">
                                <t t-foreach="state.logs" t-as="log" t-key="log.id">
                                    <div class="timeline-item">
                                        <div class="timeline-node" t-att-class="log.type"></div>
                                        <div class="timeline-content">
                                            <div class="timeline-time"><t t-esc="log.time"/></div>
                                            <div class="timeline-title"><t t-esc="log.tag"/></div>
                                            <div class="timeline-desc"><t t-esc="log.message"/></div>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </div>
                    </div>

                </div>
                </t>
            </div>
        </div>
    </t>
</templates>

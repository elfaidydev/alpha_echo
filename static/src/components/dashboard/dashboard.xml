<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="alpha_echo.Dashboard" owl="1">
        <div class="o_alpha_echo_dashboard" t-ref="dashboardMain">
            <div class="sr-v4-dashboard">

                <!-- ══ HEADER ══════════════════════════════════════════════════════ -->
                <div class="sr-header-v4">
                    <div class="header-right-side">
                        <div class="logo-box"><i class="fa fa-braille"/></div>
                        <div class="title-box">
                            <h1><t t-esc="_t('Dashboard')"/></h1>
                            <p class="subtitle"><t t-esc="_t('Central interface for tracking, reformulating, and publishing content')"/></p>
                        </div>
                    </div>
                    <div class="header-left-side">
                        <div class="health-nav">
                            <span class="status-pulse"/>
                            <t t-esc="radarState.targets.length"/> <t t-esc="_t('monitored sources')"/>
                        </div>
                        <button class="btn-primary-v4" t-on-click="toggleTracking" t-att-class="{'paused': radarState.isTracking}">
                            <t t-esc="trackingBtnLabel"/>
                            <i class="fa" t-att-class="radarState.isTracking ? 'fa-pause' : 'fa-rocket'"/>
                        </button>
                    </div>
                </div>

                <!-- ══ LOADING STATE ════════════════════════════════════════════════ -->
                <t t-if="!radarState.isConfigLoaded">
                    <div class="sr-onboarding-hero-v2 justify-content-center align-items-center">
                        <div class="onboarding-bg-blobs">
                            <div class="blob blob-1"/>
                            <div class="blob blob-2"/>
                        </div>
                        <div class="ae-loader-container text-center">
                            <div class="ae-logo-box mx-auto mb-4 ae-loader-spin">
                                <i class="fa fa-braille fa-spin"/>
                            </div>
                            <h2 class="text-white"><t t-esc="_t('Initializing Systems...')"/></h2>
                            <p class="text-white-50"><t t-esc="_t('Authenticating with cloud engines and retrieving your monitored sources.')"/></p>
                        </div>
                    </div>
                </t>
                
                <!-- ══ ONBOARDING (not yet configured) ═════════════════════════════ -->
                <t t-elif="!radarState.isOnboarded">
                    <div class="sr-onboarding-hero-v2">
                        <div class="onboarding-bg-blobs">
                            <div class="blob blob-1"/>
                            <div class="blob blob-2"/>
                        </div>
                        <div class="onboarding-main">
                            <div class="onboarding-header">
                                <h2><t t-esc="_t('Welcome to')"/> <span class="text-gradient">Alpha Echo</span></h2>
                                <p><t t-esc="_t('Automate content harvesting, formulation, and publishing with AI. Follow these steps to begin.')"/></p>
                            </div>

                            <div class="onboarding-grid grid-4-steps">

                                <!-- Step 1: X Account -->
                                <div t-attf-class="onboarding-card {{ radarState.config.twitterLinked ? 'completed' : 'pending' }}" t-on-click="openSettings">
                                    <div class="card-glow"/>
                                    <div class="card-content">
                                        <div class="step-label"><t t-esc="_t('Step 1')"/></div>
                                        <div class="step-main">
                                            <div class="step-icon">
                                                <svg viewBox="0 0 24 24" class="ae-icon-x"><g><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.007 3.56H5.022z"/></g></svg>
                                                <div t-if="radarState.config.twitterLinked" class="check-badge"><i class="fa fa-check"/></div>
                                            </div>
                                            <div class="step-info">
                                                <h4><t t-esc="_t('Link X Account')"/></h4>
                                                <p><t t-esc="_t('Authorize the system to publish via your X account.')"/></p>
                                            </div>
                                        </div>
                                        <div class="step-footer mt-2">
                                            <span t-if="radarState.config.twitterLinked" class="status-done"><t t-esc="_t('Linked')"/> <i class="fa fa-check-circle"/></span>
                                            <span t-else="" class="status-btn"><t t-esc="_t('Connect')"/> <i class="fa fa-link"/></span>
                                        </div>
                                    </div>
                                </div>

                                <!-- Step 2: AI Prompt -->
                                <t t-set="isPromptDone" t-value="radarState.config.custom_ai_instructions and radarState.config.custom_ai_instructions.length > 0"/>
                                <div t-attf-class="onboarding-card {{ isPromptDone ? 'completed' : 'pending' }}" t-on-click="openSettings">
                                    <div class="card-glow"/>
                                    <div class="card-content">
                                        <div class="step-label"><t t-esc="_t('Step 2')"/></div>
                                        <div class="step-main">
                                            <div class="step-icon">
                                                <i class="fa fa-magic"/>
                                                <div t-if="isPromptDone" class="check-badge"><i class="fa fa-check"/></div>
                                            </div>
                                            <div class="step-info">
                                                <h4><t t-esc="_t('AI Prompt')"/></h4>
                                                <p><t t-esc="_t('Define the tone and instructions for the AI engine.')"/></p>
                                            </div>
                                        </div>
                                        <div class="step-footer mt-2">
                                            <span t-if="isPromptDone" class="status-done"><t t-esc="_t('Set')"/> <i class="fa fa-check-circle"/></span>
                                            <span t-else="" class="status-btn"><t t-esc="_t('Configure')"/> <i class="fa fa-edit"/></span>
                                        </div>
                                    </div>
                                </div>

                                 <!-- Step 3: Add Targets -->
                                <t t-set="isListDone" t-value="radarState.targets.length > 0"/>
                                <div t-attf-class="onboarding-card {{ isListDone ? 'completed' : 'pending' }}" t-on-click="() => this.action.doAction('alpha_echo.targets_client_action')">
                                    <div class="card-glow"/>
                                    <div class="card-content">
                                        <div class="step-label"><t t-esc="_t('Step 3')"/></div>
                                        <div class="step-main">
                                            <div class="step-icon">
                                                <i class="fa fa-crosshairs"/>
                                                <div t-if="isListDone" class="check-badge"><i class="fa fa-check"/></div>
                                            </div>
                                            <div class="step-info">
                                                <h4><t t-esc="_t('Target Sources')"/></h4>
                                                <p><t t-esc="_t('Add at least one account you wish to monitor for updates.')"/></p>
                                            </div>
                                        </div>
                                        <div class="step-footer mt-2">
                                            <span t-if="isListDone" class="status-done"><t t-esc="_t('Sources Set')"/> <i class="fa fa-check-circle"/></span>
                                            <span t-else="" class="status-btn"><t t-esc="_t('Add Target')"/> <i class="fa fa-plus-circle"/></span>
                                        </div>
                                    </div>
                                </div>

                                 <!-- Step 4: Scraper Security -->
                                <t t-set="isCookiesDone" t-value="radarState.config.x_auth_token and radarState.config.x_ct0"/>
                                <div t-attf-class="onboarding-card {{ isCookiesDone ? 'completed' : 'pending' }}" t-on-click="openSettings">
                                    <div class="card-glow"/>
                                    <div class="card-content">
                                        <div class="step-label"><t t-esc="_t('Step 4')"/></div>
                                        <div class="step-main">
                                            <div class="step-icon">
                                                <i class="fa fa-shield"/>
                                                <div t-if="isCookiesDone" class="check-badge"><i class="fa fa-check"/></div>
                                            </div>
                                            <div class="step-info">
                                                <h4><t t-esc="_t('Scraper Connection')"/></h4>
                                                <p><t t-esc="_t('Provide auth_token and ct0 from a dedicated X reader account for scraping.')"/></p>
                                            </div>
                                        </div>
                                        <div class="step-footer mt-2">
                                            <span t-if="isCookiesDone" class="status-done"><t t-esc="_t('Authenticated')"/> <i class="fa fa-check-circle"/></span>
                                            <span t-else="" class="status-btn"><t t-esc="_t('Add Credentials')"/> <i class="fa fa-key"/></span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="onboarding-action">
                                <p class="helper-text">
                                    <t t-esc="_t('Need help? Read the')"/>
                                    <a href="#"><t t-esc="_t('Quick Start Guide')"/></a>
                                </p>
                                <button class="sr-premium-btn" t-on-click="toggleTracking" t-att-disabled="!radarState.isOnboarded">
                                    <span><t t-esc="_t('Activate Full Radar')"/></span>
                                    <i class="fa fa-bolt"/>
                                </button>
                            </div>
                        </div>
                    </div>
                </t>

                <!-- ══ MAIN DASHBOARD (fully configured) ═══════════════════════════ -->
                <t t-else="">

                    <!-- Hero Card -->
                    <div class="sr-hero-card-v4">
                        <div class="hero-content">
                            <div class="ai-sparkle-v4"><i class="fa fa-magic"/></div>
                            <div class="hero-text">
                                <h2><t t-esc="_t('Advanced exploration and analysis engine is active.')"/></h2>
                                <p>
                                    <t t-esc="_t('Currently')"/> <strong><t t-esc="radarState.targets.length"/> <t t-esc="_t('certified sources')"/></strong> <t t-esc="_t('are under real-time monitoring. Successfully captured')"/> <strong><t t-esc="radarState.grantsDiscovered"/> <t t-esc="_t('new topics')"/></strong> <t t-esc="_t('today. AI has handled professional reformulation and content has been')"/> <strong><t t-esc="_t('automatically and simultaneously')"/></strong> <t t-esc="_t('published across official channels.')"/>
                                </p>
                            </div>
                        </div>
                        <div class="hero-curve-bg"/>
                    </div>

                    <!-- Live Target Radar Strip -->
                    <div class="sr-radar-listening-v4">
                        <div class="listening-header">
                            <span><i class="fa fa-crosshairs"/> <t t-esc="_t('Live Target Map')"/> (<t t-esc="radarState.targets.length"/>)</span>
                            <div class="sweep-animation"/>
                        </div>
                        <div class="targets-marquee-container">
                            <div class="targets-marquee">
                                <t t-foreach="radarState.targets" t-as="target" t-key="target.id">
                                    <div class="target-pill"><span class="pulse-dot"/> <t t-esc="target.name"/></div>
                                </t>
                                <t t-if="radarState.targets.length === 0">
                                    <div class="target-pill ghost"><i class="fa fa-search"/> <t t-esc="_t('Searching for sources matching your criteria...')"/></div>
                                </t>
                                <!-- Duplicate for seamless marquee loop -->
                                <t t-foreach="radarState.targets" t-as="target" t-key="'dup_' + target.id">
                                    <div class="target-pill"><span class="pulse-dot"/> <t t-esc="target.name"/></div>
                                </t>
                                <t t-if="radarState.targets.length === 0">
                                    <div class="target-pill ghost"><i class="fa fa-search"/> <t t-esc="_t('Searching for sources matching your criteria...')"/></div>
                                </t>
                            </div>
                        </div>
                    </div>

                    <!-- KPI Grid -->
                    <div class="sr-kpi-grid-v4">
                        <div class="kpi-card-v4">
                            <div class="kpi-top">
                                <div class="kpi-text">
                                    <span class="kpi-title"><t t-esc="_t('New Content Captured Today')"/></span>
                                    <div class="kpi-value"><t t-esc="radarState.grantsDiscovered"/></div>
                                </div>
                                <div class="kpi-icon blue"><i class="fa fa-search-plus"/></div>
                            </div>
                            <div class="kpi-chart sparkline"><canvas t-ref="sparkline1"/></div>
                        </div>

                        <div class="kpi-card-v4">
                            <div class="kpi-top">
                                <div class="kpi-text">
                                    <span class="kpi-title"><t t-esc="_t('Publications (Website + X)')"/></span>
                                    <div class="kpi-value"><t t-esc="radarState.publishedToday"/></div>
                                </div>
                                <div class="kpi-icon emerald"><i class="fa fa-paper-plane"/></div>
                            </div>
                            <div class="kpi-chart sparkline"><canvas t-ref="sparkline2"/></div>
                        </div>

                        <div class="kpi-card-v4">
                            <div class="kpi-top">
                                <div class="kpi-text">
                                    <span class="kpi-title"><t t-esc="_t('Monitored Source Accounts')"/></span>
                                    <div class="kpi-value"><t t-esc="radarState.monitoredAccounts"/> <span><t t-esc="_t('sources')"/></span></div>
                                </div>
                                <div class="kpi-icon indigo"><i class="fa fa-users"/></div>
                            </div>
                            <!-- Visual placeholder for constant line -->
                            <div class="kpi-chart sparkline ae-kpi-placeholder-line"/>
                        </div>

                        <div class="kpi-card-v4">
                            <div class="kpi-top">
                                <div class="kpi-text">
                                    <span class="kpi-title"><t t-esc="_t('Formulation Prompt Accuracy')"/></span>
                                    <div class="kpi-value"><t t-esc="radarState.matchRate"/><span>%</span></div>
                                </div>
                                <div class="kpi-icon amber"><i class="fa fa-shield"/></div>
                            </div>
                            <div class="kpi-chart sparkline"><canvas t-ref="sparkline4"/></div>
                        </div>
                    </div>

                    <!-- Main Grid: Charts + Feed | Timeline -->
                    <div class="sr-main-grid-v4">
                        <div class="grid-primary">
                            <div class="charts-row">
                                <!-- Bar Chart -->
                                <div class="chart-card-v4 w-65">
                                    <div class="card-header">
                                        <h3>
                                            <span class="icon-pill icon-pill-indigo"><i class="fa fa-bar-chart"/></span>
                                            <t t-esc="_t('Content Flow Density by Time')"/>
                                        </h3>
                                        <span class="badge-soft"><t t-esc="_t('Live')"/></span>
                                    </div>
                                    <div class="chart-container">
                                        <canvas t-ref="barChartCanvas"/>
                                    </div>
                                </div>
                                <!-- Doughnut Chart -->
                                <div class="chart-card-v4 w-35">
                                    <div class="card-header">
                                        <h3>
                                            <span class="icon-pill icon-pill-emerald"><i class="fa fa-pie-chart"/></span>
                                            <t t-esc="_t('Automated Publishing Routing')"/>
                                        </h3>
                                    </div>
                                    <div class="chart-container doughnut-container">
                                        <canvas t-ref="gaugeChartCanvas"/>
                                        <div class="doughnut-center">
                                            <span class="d-number">100%</span>
                                            <span class="d-label"><t t-esc="_t('Dual Automation')"/></span>
                                        </div>
                                    </div>
                                    <div class="custom-chart-legend">
                                        <div class="legend-item">
                                            <div class="legend-left">
                                                <span class="legend-dot bg-indigo"/>
                                                <span><t t-esc="_t('Official Website (WordPress)')"/></span>
                                            </div>
                                        </div>
                                        <div class="legend-item">
                                            <div class="legend-left">
                                                <span class="legend-dot bg-blue"/>
                                                <span><t t-esc="_t('X Account')"/></span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Real-time Feed -->
                            <div class="feed-card-v4">
                                <div class="card-header border-bottom">
                                    <h3>
                                        <span class="icon-pill" style="background:linear-gradient(135deg,#fef3c7,#fde68a);color:#d97706;"><i class="fa fa-bolt"/></span>
                                        <t t-esc="_t('Real-time Exploration Log')"/>
                                    </h3>
                                </div>
                                <div class="feed-list-v4">
                                    <t t-if="radarState.feed.length === 0">
                                        <div class="empty-state">
                                            <i class="fa fa-microphone"/>
                                            <p><t t-esc="_t('Exploration engine is performing deep scans of certified entities...')"/></p>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <t t-foreach="radarState.feed" t-as="item" t-key="item.id">
                                            <div class="conversation-row fade-scale-up">
                                                <div class="chat-bubble raw-bubble">
                                                    <div class="bubble-header">
                                                        <span>
                                                            <svg viewBox="0 0 24 24" class="ae-icon-x ae-icon-x-sm"><g><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.007 3.56H5.022z"/></g></svg>
                                                            <t t-esc="_t('Raw Content from Source')"/>
                                                        </span>
                                                        <span class="time"><t t-esc="item.time"/></span>
                                                    </div>
                                                    <div class="bubble-text"><t t-esc="item.original"/></div>
                                                    <div class="source-tag"><t t-esc="_t('Source ID:')"/> <t t-esc="item.donor"/></div>
                                                </div>

                                                <div class="magic-arrow">
                                                    <i class="fa fa-cogs"/>
                                                    <i class="fa fa-angle-left"/>
                                                    <i class="fa fa-share-alt"/>
                                                </div>

                                                <div class="chat-bubble ai-bubble">
                                                    <div class="bubble-header ai-header">
                                                        <span><i class="fa fa-check-circle"/> <t t-esc="_t('Smart Processing &amp; Auto-Approval')"/></span>
                                                        <div class="d-flex align-items-center gap-1">
                                                            <span class="conf-badge"><i class="fa fa-globe"/> <t t-esc="_t('On Website')"/></span>
                                                            <span class="conf-badge ae-badge-x">
                                                                <svg viewBox="0 0 24 24" class="ae-icon-x ae-icon-x-xs"><g><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.007 3.56H5.022z"/></g></svg>
                                                                <t t-esc="_t('Published to X')"/>
                                                            </span>
                                                        </div>
                                                    </div>
                                                    <div class="bubble-text"><t t-esc="item.rewritten"/></div>
                                                    <div class="destination-tag">
                                                        <a t-att-href="item.tweetLink" target="_blank"><t t-esc="_t('Live Verification')"/> <i class="fa fa-external-link"/></a>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </t>
                                </div>
                            </div>
                        </div>

                        <!-- Timeline / Logs sidebar -->
                        <div class="grid-secondary">
                            <div class="timeline-card-v4">
                                <div class="card-header border-bottom">
                                    <h3>
                                        <span class="icon-pill" style="background:linear-gradient(135deg,#e0e7ff,#c7d2fe);color:#4f46e5;"><i class="fa fa-server"/></span>
                                        <t t-esc="_t('Real-time Operational Metrics')"/>
                                    </h3>
                                </div>
                                <div class="timeline-container">
                                    <t t-foreach="radarState.logs" t-as="log" t-key="log.id">
                                        <div class="timeline-item">
                                            <div class="timeline-node" t-att-class="log.type"/>
                                            <div class="timeline-content">
                                                <div class="timeline-time"><t t-esc="log.time"/></div>
                                                <div class="timeline-title"><t t-esc="log.tag"/></div>
                                                <div class="timeline-desc"><t t-esc="log.message"/></div>
                                            </div>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </div>

                </t><!-- end t-else (onboarded) -->
            </div>
        </div>
    </t>
</templates>

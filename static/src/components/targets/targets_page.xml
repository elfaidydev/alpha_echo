<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="alpha_echo.TargetsPage" owl="1">
        <div class="ae-targets-page w-100 mh-100">
            <div class="ae-container">
                <!-- ══ HEADER ══════════════════════════════════════════════════════ -->
                <div class="ae-targets-header">
                    <div class="ae-header-brand">
                        <div class="ae-logo-box">
                            <i class="fa fa-crosshairs"/>
                        </div>
                        <div class="ae-title-wrap">
                            <h1><t t-esc="_t('Resource Management')"/></h1>
                            <p class="ae-subtitle"><t t-esc="_t('Accounts auto-discovered from your X List on each scan.')"/></p>
                        </div>
                    </div>

                    <div class="ae-header-controls">
                        <!-- Search -->
                        <div class="ae-search-wrap">
                            <i class="fa fa-search ae-search-icon"/>
                            <input class="ae-search-input" type="text"
                                   t-att-placeholder="_t('Search discovered accounts...')"
                                   t-model="state.searchQuery"/>
                        </div>
                    </div>
                </div>

                <!-- ══ CONTENT GRID ══════════════════════════════════════════════ -->
                <div class="ae-targets-grid">
                    
                    <!-- Case 1: Locked State -->
                    <t t-if="!radarState.config.twitterLinked or !radarState.config.x_list_id">
                        <div class="ae-lock-screen">
                            <div class="ae-lock-card">
                                <div class="ae-lock-icon">
                                    <i t-if="!radarState.config.twitterLinked" class="fa fa-twitter"/>
                                    <i t-else="" class="fa fa-list-ul"/>
                                </div>
                                <h3><t t-esc="!radarState.config.twitterLinked ? _t('X Account Required') : _t('X List ID Required')"/></h3>
                                <p><t t-esc="!radarState.config.twitterLinked ? _t('Link your X account from Settings to activate discovery.') : _t('Add your X List URL or ID in Settings to start monitoring targets.')"/></p>
                            </div>
                        </div>
                    </t>

                    <!-- Case 2: Loading -->
                    <t t-elif="radarState.isLoading and targets.length === 0">
                        <div class="ae-loading-state">
                            <div class="ae-loader"></div>
                            <p>Discovering targets from X...</p>
                        </div>
                    </t>

                    <!-- Force Preview Mode with Dummy Data -->
                    <t t-if="true">

                        <!-- Dummy Target 1 -->
                        <div class="ae-target-card ae-dummy" t-on-click="() => this.openTargetAnalytics({id: 't1', name: 'Saudi News Network', handle: 'SaudiNewsNet', posts_count: 154, is_active: true})">
                            <div class="ae-card-glow glow-indigo"/>
                            <div class="ae-card-head">
                                <div class="ae-target-info">
                                    <h3>Saudi News Network</h3>
                                    <span class="ae-handle"><i class="fa fa-at"/> SaudiNewsNet</span>
                                </div>
                            </div>
                            <div class="ae-card-body">
                                <div class="ae-stat-row">
                                    <div class="ae-stat">
                                        <span class="label">Captured</span>
                                        <span class="value"><i class="fa fa-bolt"/> 154</span>
                                    </div>
                                    <div class="ae-stat">
                                        <span class="label">Priority</span>
                                        <span class="value text-emerald">High</span>
                                    </div>
                                </div>
                            </div>
                            <div class="ae-card-foot">
                                <span class="ae-status-tag active"><span class="ae-dot"/>Monitoring</span>
                                <span class="ae-hint">Click for analytics</span>
                            </div>
                        </div>

                        <!-- Dummy Target 2 -->
                        <div class="ae-target-card ae-dummy" t-on-click="() => this.openTargetAnalytics({id: 't2', name: 'Al Arabiya Business', handle: 'AlArabiya_Bn', posts_count: 89, is_active: true})">
                            <div class="ae-card-glow glow-emerald"/>
                            <div class="ae-card-head">
                                <div class="ae-target-info">
                                    <h3>Al Arabiya Business</h3>
                                    <span class="ae-handle"><i class="fa fa-at"/> AlArabiya_Bn</span>
                                </div>
                            </div>
                            <div class="ae-card-body">
                                <div class="ae-stat-row">
                                    <div class="ae-stat">
                                        <span class="label">Captured</span>
                                        <span class="value"><i class="fa fa-bolt"/> 89</span>
                                    </div>
                                    <div class="ae-stat">
                                        <span class="label">Source</span>
                                        <span class="value">Official</span>
                                    </div>
                                </div>
                            </div>
                            <div class="ae-card-foot">
                                <span class="ae-status-tag active"><span class="ae-dot"/>Monitoring</span>
                                <span class="ae-hint">Click for analytics</span>
                            </div>
                        </div>

                        <!-- Dummy Target 3 -->
                        <div class="ae-target-card ae-dummy" t-on-click="() => this.openTargetAnalytics({id: 't3', name: 'UAE Tech Insights', handle: 'UAETech', posts_count: 42, is_active: true})">
                            <div class="ae-card-glow glow-indigo"/>
                            <div class="ae-card-head">
                                <div class="ae-target-info">
                                    <h3>UAE Tech Insights</h3>
                                    <span class="ae-handle"><i class="fa fa-at"/> UAETech</span>
                                </div>
                            </div>
                            <div class="ae-card-body">
                                <div class="ae-stat-row">
                                    <div class="ae-stat">
                                        <span class="label">Captured</span>
                                        <span class="value"><i class="fa fa-bolt"/> 42</span>
                                    </div>
                                    <div class="ae-stat">
                                        <span class="label">Scan Type</span>
                                        <span class="value">Automatic</span>
                                    </div>
                                </div>
                            </div>
                            <div class="ae-card-foot">
                                <span class="ae-status-tag active"><span class="ae-dot"/>Monitoring</span>
                                <span class="ae-hint">Click for analytics</span>
                            </div>
                        </div>

                        <!-- Dummy Target 4 -->
                        <div class="ae-target-card ae-dummy" t-on-click="() => this.openTargetAnalytics({id: 't4', name: 'Economic World', handle: 'EcoWorld', posts_count: 215, is_active: true})">
                            <div class="ae-card-glow glow-rose"/>
                            <div class="ae-card-head">
                                <div class="ae-target-info">
                                    <h3>Economic World</h3>
                                    <span class="ae-handle"><i class="fa fa-at"/> EcoWorld</span>
                                </div>
                            </div>
                            <div class="ae-card-body">
                                <div class="ae-stat-row">
                                    <div class="ae-stat">
                                        <span class="label">Captured</span>
                                        <span class="value"><i class="fa fa-bolt"/> 215</span>
                                    </div>
                                    <div class="ae-stat">
                                        <span class="label">Status</span>
                                        <span class="value text-rose">Critcal</span>
                                    </div>
                                </div>
                            </div>
                            <div class="ae-card-foot">
                                <span class="ae-status-tag active"><span class="ae-dot"/>Monitoring</span>
                                <span class="ae-hint">Click for analytics</span>
                            </div>
                        </div>

                        <!-- Dummy Target 5 -->
                        <div class="ae-target-card ae-dummy" t-on-click="() => this.openTargetAnalytics({id: 't5', name: 'Vision 2030 News', handle: 'KSA_V2030', posts_count: 312, is_active: true})">
                            <div class="ae-card-glow glow-emerald"/>
                            <div class="ae-card-head">
                                <div class="ae-target-info">
                                    <h3>Vision 2030 News</h3>
                                    <span class="ae-handle"><i class="fa fa-at"/> KSA_V2030</span>
                                </div>
                            </div>
                            <div class="ae-card-body">
                                <div class="ae-stat-row">
                                    <div class="ae-stat">
                                        <span class="label">Captured</span>
                                        <span class="value"><i class="fa fa-bolt"/> 312</span>
                                    </div>
                                    <div class="ae-stat">
                                        <span class="label">Growth</span>
                                        <span class="value text-emerald">+24%</span>
                                    </div>
                                </div>
                            </div>
                            <div class="ae-card-foot">
                                <span class="ae-status-tag active"><span class="ae-dot"/>Monitoring</span>
                                <span class="ae-hint">Click for analytics</span>
                            </div>
                        </div>

                        <!-- Dummy Target 6 -->
                        <div class="ae-target-card ae-dummy" t-on-click="() => this.openTargetAnalytics({id: 't6', name: 'Riyadh Business', handle: 'RiyadhBiz', posts_count: 67, is_active: true})">
                            <div class="ae-card-glow glow-indigo"/>
                            <div class="ae-card-head">
                                <div class="ae-target-info">
                                    <h3>Riyadh Business</h3>
                                    <span class="ae-handle"><i class="fa fa-at"/> RiyadhBiz</span>
                                </div>
                            </div>
                            <div class="ae-card-body">
                                <div class="ae-stat-row">
                                    <div class="ae-stat">
                                        <span class="label">Captured</span>
                                        <span class="value"><i class="fa fa-bolt"/> 67</span>
                                    </div>
                                    <div class="ae-stat">
                                        <span class="label">Update</span>
                                        <span class="value">Hourly</span>
                                    </div>
                                </div>
                            </div>
                            <div class="ae-card-foot">
                                <span class="ae-status-tag active"><span class="ae-dot"/>Monitoring</span>
                                <span class="ae-hint">Click for analytics</span>
                            </div>
                        </div>
                    </t>

                    <!-- Real Targets -->
                    <t t-else="">
                        <t t-foreach="filteredTargets" t-as="target" t-key="target.id">
                            <div class="ae-target-card" t-on-click="() => this.openTargetAnalytics(target)">
                                <div class="ae-card-glow glow-indigo"/>
                                <div class="ae-card-head">
                                    <div class="ae-target-info">
                                        <h3><t t-esc="target.name"/></h3>
                                        <span class="ae-handle" t-if="target.handle"><i class="fa fa-at"/> <t t-esc="target.handle"/></span>
                                    </div>
                                </div>
                                <div class="ae-card-body">
                                    <div class="ae-stat-row">
                                        <div class="ae-stat">
                                            <span class="label">Captured Content</span>
                                            <span class="value"><i class="fa fa-bolt"/> <t t-esc="target.posts_count"/></span>
                                        </div>
                                    </div>
                                </div>
                                <div class="ae-card-foot">
                                    <span class="ae-status-tag active"><span class="ae-dot"/>Monitoring Active</span>
                                    <span class="ae-hint">Click for analytics</span>
                                </div>
                            </div>
                        </t>
                    </t>
                </div>
            </div>

            <!-- ══ ANALYTICS MODAL ══════════════════════════════════════════════ -->
            <t t-if="state.selectedTarget">
                <div class="ae-modal-overlay" t-on-click.self="closeTargetAnalytics">
                    <div class="ae-modal ae-analytics-modal">
                        <div class="ae-modal-header">
                            <div class="ae-modal-brand">
                                <div class="ae-modal-icon"><i class="fa fa-crosshairs"/></div>
                                <div>
                                    <h3><t t-esc="state.selectedTarget.name"/></h3>
                                    <span class="ae-modal-date" t-if="state.selectedTarget.handle"><i class="fa fa-at"/> <t t-esc="state.selectedTarget.handle"/></span>
                                </div>
                            </div>
                            <button class="ae-modal-close" t-on-click="closeTargetAnalytics"><i class="fa fa-times"/></button>
                        </div>

                        <div class="ae-modal-body">
                            <t t-call="alpha_echo.TargetsPage.AnalyticsView"/>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>

    <!-- Sub-Template: Analytics View -->
    <t t-name="alpha_echo.TargetsPage.AnalyticsView" owl="1">
        <div class="ae-analytics-content">
            <div class="ae-analytics-grid">
                <!-- Left: Stats -->
                <div class="ae-analytics-col">
                    <div class="ae-insight-card">
                        <h4>Target Insights</h4>
                        <div class="ae-stat-group">
                            <div class="ae-stat-item">
                                <span class="label">Engine Status</span>
                                <span class="value text-emerald">Active &amp; Capturing</span>
                            </div>
                            <div class="ae-stat-item">
                                <span class="label">Total Discoveries</span>
                                <span class="value big"><t t-esc="state.selectedTarget.posts_count"/></span>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Right: Timeline -->
                <div class="ae-analytics-col">
                    <div class="ae-timeline-card">
                        <h4><i class="fa fa-feed"/> Recent Timeline</h4>
                        <div class="ae-timeline">
                            <t t-if="state.targetRecentPosts.length === 0">
                                <div class="ae-timeline-empty">Loading latest updates...</div>
                            </t>
                            <t t-else="">
                                <t t-foreach="state.targetRecentPosts" t-as="post" t-key="post.id">
                                    <div class="ae-timeline-item">
                                        <div t-attf-class="ae-timeline-dot {{ post.state === 'published' ? 'bg-emerald' : 'bg-indigo' }}"/>
                                        <div class="ae-timeline-content">
                                            <div class="ae-timeline-head">
                                                <span t-attf-class="ae-badge {{ post.state === 'published' ? 'badge-published' : 'badge-draft' }}">
                                                    <t t-esc="this.getPostStatusLabel(post.state)"/>
                                                </span>
                                                <small><t t-esc="post.create_date.split(' ')[0]"/></small>
                                            </div>
                                            <p><t t-esc="post.ai_generated_text ? post.ai_generated_text.substring(0, 100) + '...' : post.original_text.substring(0, 100) + '...'"/></p>
                                        </div>
                                    </div>
                                </t>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>

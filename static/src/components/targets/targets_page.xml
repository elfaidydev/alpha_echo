<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="alpha_echo.TargetsPage" owl="1">
        <div class="sr-targets-container">
            <!-- Premium 3-Row Header -->
            <div class="sr-targets-header vertical-layout">
                <!-- Row 1: Logo and Title -->
                <div class="sr-header-row info-row">
                    <div class="logo-box">
                        <i class="fa fa-crosshairs"/>
                    </div>
                    <div class="title-box">
                         <h1><t t-esc="_t('Resource Management')"/></h1>
                         <p class="subtitle"><t t-esc="_t('Accounts auto-discovered from your X/Twitter List.')"/></p>
                    </div>
                </div>

                <div class="sr-header-row search-row gap-3">
                    <div class="sr-search-bar flex-grow-1">
                        <i class="fa fa-search"/>
                        <input type="text" t-model="state.searchQuery" t-att-placeholder="_t('Search discovered accounts...')"/>
                    </div>
                </div>

                <!-- Categories removed as per Auto-Discovery changes -->
            </div>

            <!-- Content Grid -->
            <div class="sr-targets-grid">
                <!-- Case 1: X Account not linked OR List ID missing -->
                <t t-if="!radarState.config.twitterLinked or !radarState.config.x_list_id">
                    <div class="sr-premium-lock-screen full-width-lock">
                        <div class="lock-bg-pattern"></div>
                        <div class="lock-content fade-scale-up">
                            <div class="lock-icon-wrapper">
                                <div class="lock-shield text-warning"><i class="fa fa-exclamation-triangle"/></div>
                                <div class="lock-main-icon"><i class="fa fa-link"/></div>
                            </div>
                            <div class="lock-text">
                                <h3 t-if="!radarState.config.twitterLinked">X Account Required <span class="badge-locked">Step 1</span></h3>
                                <h3 t-else="">Twitter List ID Required <span class="badge-locked">Step 2</span></h3>
                                <p t-if="!radarState.config.twitterLinked">Please link your X (Twitter) account in Settings to start using the engine.</p>
                                <p t-else="">Almost there! You must provide a <b>Private X List ID</b> in Settings to discover and monitor accounts.</p>
                                <button class="btn btn-primary mt-3 rounded-pill px-4" t-on-click="() => this.actionService.doAction('alpha_echo.action_alpha_echo_config_settings_client')">
                                    Go to Settings
                                </button>
                            </div>
                        </div>
                    </div>
                </t>
                <t t-elif="radarState.isLoading">
                    <div class="sr-loading-state" style="grid-column: 1 / -1;">
                        <div class="dot-spin"></div>
                        <p>Synchronizing monitoring network...</p>
                    </div>
                </t>
                <t t-elif="targets.length === 0 and !radarState.isLoading">
                    <div class="sr-premium-empty-state" style="grid-column: 1 / -1;">
                        <div class="empty-icon-wrap"><i class="fa fa-satellite-dish pulse-icon"/></div>
                        <h2>No accounts discovered yet</h2>
                        <p>Your Twitter List is connected, but no accounts have been discovered from it yet. Wait for the first automated scan or trigger it manually.</p>
                        <button class="btn btn-primary mt-3 rounded-pill px-4" t-on-click="syncListMembers">
                             Trigger Manual Sync
                        </button>
                    </div>
                </t>
                <t t-elif="filteredTargets.length === 0 and !radarState.isLoading">
                    <div class="sr-empty-state" style="grid-column: 1 / -1;">
                        <i class="fa fa-crosshairs"/>
                        <p>No accounts match the current search.</p>
                    </div>
                </t>
                <t t-else="">
                    <t t-foreach="filteredTargets" t-as="target" t-key="target.id">
                        <div class="sr-target-card">
                            <div class="sr-card-bg-glow glow-success"></div>

                            <div class="sr-card-head d-flex justify-content-between align-items-center">
                                <div class="sr-target-identity d-flex align-items-center gap-2" t-on-click="() => this.openTargetAnalytics(target)">
                                    <div class="sr-target-info d-flex flex-column align-items-start">
                                        <h3 class="sr-target-name m-0">
                                            <t t-esc="target.name"/>
                                        </h3>
                                        <span class="sr-target-handle" t-if="target.handle">
                                            <i class="fa fa-twitter"/> <t t-esc="target.handle"/>
                                        </span>
                                    </div>
                                </div>
                                <div class="sr-actions-btns d-flex gap-2">
                                    <button class="btn btn-link text-danger p-0" t-on-click.stop="() => this.deleteTarget(target.id)" title="Delete Target">
                                        <i class="fa fa-trash"/>
                                    </button>
                                    <div class="sr-status-badge" t-on-click="() => this.openTargetAnalytics(target)">
                                        <i class="fa fa-check-circle text-success"/>
                                    </div>
                                </div>
                            </div>

                            <div class="sr-card-body" t-on-click="() => this.openTargetAnalytics(target)">
                                <div class="sr-stats-row">
                                    <!-- Category badge removed -->
                                    <div class="sr-stat-box">
                                        <span class="stat-label">Captured Content</span>
                                        <span class="stat-value text-indigo">
                                            <i class="fa fa-bolt"/> <t t-esc="target.posts_count"/>
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <div class="sr-card-foot" t-on-click="() => this.openTargetAnalytics(target)">
                                <span class="sr-engine-status recording">
                                    <span class="pulse-dot"></span>
                                    Monitoring Active
                                </span>
                            </div>
                        </div>
                    </t>
                </t>
            </div>

            <!-- Target Analytics Modal -->
            <t t-if="state.selectedTarget">
                <div class="sr-modal-overlay" t-on-click.self="closeTargetAnalytics">
                    <div class="sr-modal-content fade-in-scale">
                        <!-- Modal Header -->
                        <div class="sr-modal-header">
                            <div class="sr-modal-title-block">
                                <h2 class="sr-modal-title">
                                    <t t-esc="state.selectedTarget.name"/>
                                    <span class="pulse-dot-small bg-success"/>
                                </h2>
                                <span class="sr-modal-handle" t-if="state.selectedTarget.handle">
                                    <i class="fa fa-twitter"/> <t t-esc="state.selectedTarget.handle"/>
                                </span>
                            </div>
                            <button class="sr-close-btn" t-on-click="closeTargetAnalytics" title="Close">
                                <i class="fa fa-times"/>
                            </button>
                        </div>

                        <!-- Modal Body — Analytics only (read-only) -->
                        <div class="sr-modal-body bg-light-mesh">
                            <t t-call="alpha_echo.TargetsPage.AnalyticsView"/>
                        </div>
                        
                        <!-- No footer button needed as requested -->
                    </div>
                </div>
            </t>
        </div>
    </t>

    <!-- ============================================== -->
    <!-- SUB-TEMPLATE: Analytics View (VIEW MODE)       -->
    <!-- ============================================== -->
    <t t-name="alpha_echo.TargetsPage.AnalyticsView" owl="1">
        <div class="row g-4 m-0">
            <!-- Left Analytics Card -->
            <div class="col-md-5">
                <div class="sr-insight-card p-4 bg-white rounded-4 shadow-sm h-100 border-0">
                    <h4 class="fs-6 fw-bold text-muted mb-4 text-uppercase tracking-wide">Target Overview</h4>

                    <div class="d-flex justify-content-between align-items-center mb-3 pb-3 border-bottom">
                        <span class="text-secondary fw-semibold">Monitoring Status (Engine)</span>
                        <span t-attf-class="badge rounded-pill {{state.selectedTarget.is_active ? 'bg-success-subtle text-success' : 'bg-secondary-subtle text-secondary'}} fs-6 px-3 py-2">
                            <i t-attf-class="fa fa-{{state.selectedTarget.is_active ? 'check-circle' : 'pause-circle'}} me-1"/>
                            <t t-esc="this.getSelectedTargetStatusLabel()"/>
                        </span>
                    </div>

                    <!-- Source Category removed -->

                    <div class="d-flex justify-content-between align-items-center bg-indigo-50 p-3 rounded-3 mt-4">
                        <div>
                            <span class="d-block text-indigo fw-bold fs-6">Total Discoveries</span>
                            <span class="text-muted small">Topics and content captured</span>
                        </div>
                        <h2 class="text-indigo mb-0 fw-black"><t t-esc="state.selectedTarget.posts_count"/></h2>
                    </div>
                </div>
            </div>

            <!-- Right Live Feed Timeline -->
            <div class="col-md-7">
                <div class="sr-insight-card p-4 bg-white rounded-4 shadow-sm h-100 border-0">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h4 class="fs-6 fw-bold text-dark mb-0"><i class="fa fa-feed text-primary me-2"/> Live Feed (Latest 5 Topics)</h4>
                        <div t-if="state.targetRecentPosts.length === 0" class="spinner-border spinner-border-sm text-primary" role="status"></div>
                    </div>

                    <div class="sr-timeline pe-2">
                        <t t-if="state.targetRecentPosts.length === 0">
                            <p class="text-muted text-center py-4">Loading timeline...</p>
                        </t>
                        <t t-else="">
                            <t t-foreach="state.targetRecentPosts" t-as="post" t-key="post.id">
                                <div class="timeline-item slide-in-right" t-attf-style="animation-delay: {{post_index * 0.1}}s">
                                    <div class="timeline-marker" t-att-class="post.state === 'published' ? 'bg-success' : (post.state === 'draft' ? 'bg-warning' : 'bg-danger')"></div>
                                    <div class="timeline-content p-3 rounded-3 bg-light border border-light-subtle mb-3">
                                        <div class="d-flex justify-content-between mb-2">
                                            <span class="badge" t-att-class="post.state === 'published' ? 'text-bg-success' : (post.state === 'draft' ? 'text-bg-warning' : 'text-bg-danger')">
                                                <t t-esc="this.getPostStatusLabel(post.state)"/>
                                            </span>
                                            <small class="text-muted fw-bold"><i class="fa fa-clock-o me-1"/> <t t-esc="post.create_date.split(' ')[0]"/></small>
                                        </div>
                                        <p class="ai-text-snippet mb-2 text-dark fs-6" style="line-height: 1.7; font-weight: 500;">
                                            <t t-esc="post.ai_generated_text ? post.ai_generated_text.substring(0, 130) + '...' : post.original_text.substring(0, 130) + '...'"/>
                                        </p>
                                    </div>
                                </div>
                            </t>
                        </t>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>

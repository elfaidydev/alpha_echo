<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="alpha_echo.TargetsPage" owl="1">
        <div class="ae-targets-page w-100 mh-100">
            <div class="ae-container">
                <!-- ══ HEADER ══════════════════════════════════════════════════════ -->
                <div class="ae-targets-header">
                    <div class="ae-header-brand">
                        <div class="ae-logo-box">
                            <i class="fa fa-crosshairs"/>
                        </div>
                        <div class="ae-title-wrap">
                            <h1><t t-esc="_t('Resource Management')"/></h1>
                            <p class="ae-subtitle"><t t-esc="_t('Accounts auto-discovered from your X List on each scan.')"/></p>
                        </div>
                    </div>

                    <div class="ae-header-controls">
                        <!-- Search -->
                        <div class="ae-search-wrap">
                            <i class="fa fa-search ae-search-icon"/>
                            <input class="ae-search-input" type="text"
                                   t-att-placeholder="_t('Search discovered accounts...')"
                                   t-model="state.searchQuery"/>
                        </div>
                    </div>
                </div>

                <!-- ══ CONTENT GRID ══════════════════════════════════════════════ -->
                <div class="ae-targets-grid">

                    <!-- Case 1: Locked — X account not connected -->
                    <t t-if="!radarState.config.twitterLinked">
                        <div class="ae-empty-hero">
                            <div class="ae-empty-hero-ring"/>
                            <div class="ae-empty-icon ae-empty-icon-lock">
                                <i class="fa fa-twitter"/>
                            </div>
                            <h2><t t-esc="_t('X Account Required')"/></h2>
                            <p><t t-esc="_t('Link your X account from Settings to activate discovery.')"/></p>
                            <div class="ae-empty-actions">
                                <a class="ae-btn-hero ae-btn-hero-primary" href="/odoo/alpha-echo/config">
                                    <i class="fa fa-plug"/> <t t-esc="_t('Go to Settings')"/>
                                </a>
                            </div>
                        </div>
                    </t>

                    <!-- Case 1b: Locked — X List not set -->
                    <t t-elif="!radarState.config.x_list_id">
                        <div class="ae-empty-hero">
                            <div class="ae-empty-hero-ring ae-ring-amber"/>
                            <div class="ae-empty-icon ae-empty-icon-amber">
                                <i class="fa fa-list-ul"/>
                            </div>
                            <h2><t t-esc="_t('X List ID Required')"/></h2>
                            <p><t t-esc="_t('Add your X List URL or ID in Settings to start monitoring targets.')"/></p>
                            <div class="ae-empty-actions">
                                <a class="ae-btn-hero ae-btn-hero-amber" href="/odoo/alpha-echo/config">
                                    <i class="fa fa-cog"/> <t t-esc="_t('Configure Now')"/>
                                </a>
                            </div>
                        </div>
                    </t>

                    <!-- Case 2: Loading -->
                    <t t-elif="radarState.isLoading and filteredTargets.length === 0">
                        <div class="ae-empty-hero">
                            <div class="ae-empty-icon ae-empty-icon-spin">
                                <i class="fa fa-spinner fa-spin"/>
                            </div>
                            <h2><t t-esc="_t('Discovering Targets...')"/></h2>
                            <p><t t-esc="_t('Scanning your X List for monitored accounts.')"/></p>
                        </div>
                    </t>

                    <!-- Case 3: Empty — configured but no targets yet -->
                    <t t-elif="filteredTargets.length === 0">
                        <div class="ae-empty-hero">
                            <div class="ae-empty-hero-ring"/>
                            <div class="ae-empty-icon">
                                <i class="fa fa-crosshairs"/>
                            </div>
                            <h2><t t-esc="_t('No Targets Found')"/></h2>
                            <p><t t-esc="_t('No accounts have been discovered yet. Make sure your X List is configured, then trigger a scan.')"/></p>
                            <div class="ae-empty-actions">
                                <a class="ae-btn-hero ae-btn-hero-primary" href="/odoo/alpha-echo/config">
                                    <i class="fa fa-refresh"/> <t t-esc="_t('Trigger a Scan')"/>
                                </a>
                            </div>
                        </div>
                    </t>

                    <!-- Case 4: Real Targets -->
                    <t t-else="">
                        <t t-foreach="filteredTargets" t-as="target" t-key="target.id">
                            <div class="ae-target-card" t-on-click="() => this.openTargetAnalytics(target)">
                                <div class="ae-card-glow glow-indigo"/>
                                <div class="ae-card-head">
                                    <div class="ae-target-info">
                                        <h3><t t-esc="target.name"/></h3>
                                        <span class="ae-handle" t-if="target.handle"><i class="fa fa-at"/> <t t-esc="target.handle"/></span>
                                    </div>
                                </div>
                                <div class="ae-card-body">
                                    <div class="ae-stat-row">
                                        <div class="ae-stat">
                                            <span class="label"><t t-esc="_t('Captured')"/></span>
                                            <span class="value"><i class="fa fa-bolt"/> <t t-esc="target.posts_count"/></span>
                                        </div>
                                        <div class="ae-stat">
                                            <span class="label"><t t-esc="_t('Status')"/></span>
                                            <span t-attf-class="value {{ target.is_active ? 'text-emerald' : '' }}">
                                                <t t-esc="this.getEngineStatusLabel(target.is_active)"/>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                <div class="ae-card-foot">
                                    <span class="ae-status-tag active"><span class="ae-dot"/><t t-esc="_t('Monitoring Active')"/></span>
                                    <span class="ae-hint"><t t-esc="_t('Click for analytics')"/></span>
                                </div>
                            </div>
                        </t>
                    </t>

                </div>
            </div>

            <!-- ══ ANALYTICS MODAL ══════════════════════════════════════════════ -->
            <t t-if="state.selectedTarget">
                <div class="ae-modal-overlay" t-on-click.self="closeTargetAnalytics">
                    <div class="ae-modal ae-analytics-modal">
                        <div class="ae-modal-header">
                            <div class="ae-modal-brand">
                                <div class="ae-modal-icon"><i class="fa fa-crosshairs"/></div>
                                <div>
                                    <h3><t t-esc="state.selectedTarget.name"/></h3>
                                    <span class="ae-modal-date" t-if="state.selectedTarget.handle"><i class="fa fa-at"/> <t t-esc="state.selectedTarget.handle"/></span>
                                </div>
                            </div>
                            <button class="ae-modal-close" t-on-click="closeTargetAnalytics"><i class="fa fa-times"/></button>
                        </div>

                        <div class="ae-modal-body">
                            <t t-call="alpha_echo.TargetsPage.AnalyticsView"/>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>

    <!-- Sub-Template: Analytics View -->
    <t t-name="alpha_echo.TargetsPage.AnalyticsView" owl="1">
        <div class="ae-analytics-content">
            <div class="ae-analytics-grid">
                <!-- Left: Stats -->
                <div class="ae-analytics-col">
                    <div class="ae-insight-card">
                        <h4><t t-esc="_t('Target Insights')"/></h4>
                        <div class="ae-stat-group">
                            <div class="ae-stat-item">
                                <span class="label"><t t-esc="_t('Engine Status')"/></span>
                                <span class="value text-emerald"><t t-esc="this.getSelectedTargetStatusLabel()"/></span>
                            </div>
                            <div class="ae-stat-item">
                                <span class="label"><t t-esc="_t('Total Discoveries')"/></span>
                                <span class="value big"><t t-esc="state.selectedTarget.posts_count"/></span>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Right: Timeline -->
                <div class="ae-analytics-col">
                    <div class="ae-timeline-card">
                        <h4><i class="fa fa-feed"/> <t t-esc="_t('Recent Timeline')"/></h4>
                        <div class="ae-timeline">
                            <t t-if="state.targetRecentPosts.length === 0">
                                <div class="ae-timeline-empty"><t t-esc="_t('Loading latest updates...')"/></div>
                            </t>
                            <t t-else="">
                                <t t-foreach="state.targetRecentPosts" t-as="post" t-key="post.id">
                                    <div class="ae-timeline-item">
                                        <div t-attf-class="ae-timeline-dot {{ post.state === 'published' ? 'bg-emerald' : 'bg-indigo' }}"/>
                                        <div class="ae-timeline-content">
                                            <div class="ae-timeline-head">
                                                <span t-attf-class="ae-badge {{ post.state === 'published' ? 'badge-published' : 'badge-draft' }}">
                                                    <t t-esc="this.getPostStatusLabel(post.state)"/>
                                                </span>
                                                <small><t t-esc="post.create_date.split(' ')[0]"/></small>
                                            </div>
                                            <p><t t-esc="post.ai_generated_text ? post.ai_generated_text.substring(0, 100) + '...' : post.original_text.substring(0, 100) + '...'"/></p>
                                        </div>
                                    </div>
                                </t>
                            </t>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </t>

</templates>
